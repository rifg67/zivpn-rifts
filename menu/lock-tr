#!/bin/bash

# Color Definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BG_BLUE='\033[44;1m'
BG_GREEN='\033[42;1m'
BG_RED='\033[41;1m'
NC='\033[0m'
BOLD='\033[1m'

# Animation Characters
SPINNER=("⣷" "⣯" "⣟" "⡿" "⢿" "⣻" "⣽" "⣾")

# Loading animation
show_loading() {
    local text=$1
    echo -ne "${CYAN}${text} ${NC}"
    for i in {1..3}; do
        for char in "${SPINNER[@]}"; do
            echo -ne "\r${CYAN}${text} $char ${NC}"
            sleep 0.1
        done
    done
    echo -ne "\r${GREEN}${text} ✓ ${NC}"
    echo
}

# Function to display header
display_header() {
    clear
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${YELLOW}        ╔═══════════════════════════╗${BLUE}            │${NC}"
    echo -e "${BLUE}│${YELLOW}        ║   🔒 LOCK TROJAN ACCOUNT   ║${BLUE}           │${NC}"
    echo -e "${BLUE}│${YELLOW}        ║   Premium Edition         ║${BLUE}            │${NC}"
    echo -e "${BLUE}│${YELLOW}        ╚═══════════════════════════╝${BLUE}            │${NC}"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
    echo
}

# ==================== BOT CONFIGURATION (DARI /etc/zivpn/bot-config.json) ====================
BOT_CONFIG="/etc/zivpn/bot-config.json"

get_bot_config() {
    if [ -f "$BOT_CONFIG" ]; then
        KEY=$(grep -o '"bot_token": "[^"]*"' "$BOT_CONFIG" | cut -d'"' -f4)
        CHATID=$(grep -o '"admin_id": [0-9]*' "$BOT_CONFIG" | cut -d' ' -f2)
        echo "$KEY|$CHATID"
    else
        echo "|"
    fi
}

BOT_INFO=$(get_bot_config)
KEY=$(echo "$BOT_INFO" | cut -d'|' -f1)
CHATID=$(echo "$BOT_INFO" | cut -d'|' -f2)
TIME="10"
URL="https://api.telegram.org/bot$KEY/sendMessage"

# Function send log
function send_log(){
    if [ -n "$CHATID" ] && [ -n "$KEY" ]; then
        TEXT="
<code>────────────────────
<b>⚠️ NOTIFICATIONS LOCK TROJAN ⚠️</b>
────────────────────
Username  : $user
Expired   : ${exp}
Status    : LOCKED
────────────────────</code>
"
        curl -s --max-time $TIME -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" $URL >/dev/null
    fi
}

nama=$(cat /etc/zivpn/username 2>/dev/null || echo "PEYX TUNNEL")

# ==================== FUNGSI LOCK ====================
function cek_lock() {
    mkdir -p /etc/peyx/lock
    if [ ! -f "/etc/peyx/lock/trojan.db" ]; then
        touch /etc/peyx/lock/trojan.db
    fi
}

cek_lock

# Main Display
display_header

# TAMPILAN DAFTAR ACCOUNT DARI DATABASE
NUMBER_OF_CLIENTS=$(grep -c "^###" /etc/peyx/trojan.db 2>/dev/null)
if [[ ${NUMBER_OF_CLIENTS} == '0' ]]; then
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${WHITE}              ⚠️ NO ACCOUNTS FOUND${BLUE}              │${NC}"
    echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
    echo -e "${BLUE}│${WHITE}        No Trojan accounts available to lock${BLUE}   │${NC}"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
    echo
    echo -e "${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
    exit 1
fi

echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
echo -e "${BLUE}│${WHITE}              📊 TROJAN ACCOUNTS${BLUE}                 │${NC}"
echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
echo -e "${BLUE}│${WHITE}  USERNAME         EXP DATE         STATUS${BLUE}       │${NC}"
echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"

# Menampilkan user dari database dengan status lock/unlock
while IFS= read -r line; do
    if [[ "$line" =~ ^### ]]; then
        username=$(echo "$line" | awk '{print $2}')
        exp_date=$(echo "$line" | awk '{print $3}')
        
        # Cek apakah akun terkunci di database lock
        if grep -q "^### $username" "/etc/peyx/lock/trojan.db" 2>/dev/null; then
            status="${RED}LOCKED${NC}"
        else
            status="${GREEN}UNLOCKED${NC}"
        fi
        
        printf "${BLUE}│${WHITE}  %-15s %-15s " "$username" "$exp_date"
        echo -e "${status}${BLUE}       │${NC}"
    fi
done < /etc/peyx/trojan.db

echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
printf "${BLUE}│${WHITE} %-16s: ${GREEN}%-26s${BLUE}    │${NC}\n" "Total Accounts" "$NUMBER_OF_CLIENTS users"
echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
echo

# Input username
read -rp " Input Username    : " user

if [ -z "$user" ]; then
    exit 1
else
    show_loading "Locking Trojan account $user"
    
    # Cek apakah user ada di database
    if grep -q "^### $user " /etc/peyx/trojan.db 2>/dev/null; then
        exp=$(grep "^### $user " /etc/peyx/trojan.db | awk '{print $3}')
        
        # Cek apakah akun sudah terkunci
        if grep -q "^### $user" "/etc/peyx/lock/trojan.db" 2>/dev/null; then
            display_header
            echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
            echo -e "${BLUE}│${WHITE}            ⚠️ ACCOUNT ALREADY LOCKED${BLUE}         │${NC}"
            echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
            printf "${BLUE}│${WHITE} %-12s: ${CYAN}%-30s${BLUE}    │${NC}\n" "Username" "$user"
            printf "${BLUE}│${WHITE} %-12s: ${RED}%-30s${BLUE}    │${NC}\n" "Status" "Already LOCKED"
            echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
            echo
            echo -e "${CYAN}Press Enter to continue...${NC}"
            read -n 1 -s
        else
            # ==================== LOCK ACCOUNT ====================
            # Hapus user dari config Xray
            jq --arg user "$user" '.inbounds |= map(if .protocol == "trojan" then .settings.clients |= map(select(.email != $user)) else . end)' /usr/local/etc/xray/config.json > /usr/local/etc/xray/config.json.tmp && mv /usr/local/etc/xray/config.json.tmp /usr/local/etc/xray/config.json
            
            # Simpan ke database lock untuk history
            echo "### $user $exp" >> /etc/peyx/lock/trojan.db
            
            # Restart Xray
            systemctl restart xray > /dev/null 2>&1
            
            # TAMPILAN HASIL
            display_header
            echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
            echo -e "${BLUE}│${WHITE}              ✅ ACCOUNT LOCKED${BLUE}                  │${NC}"
            echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
            printf "${BLUE}│${WHITE} %-12s: ${CYAN}%-30s${BLUE}    │${NC}\n" "Username" "$user"
            printf "${BLUE}│${WHITE} %-12s: ${CYAN}%-30s${BLUE}    │${NC}\n" "Expired" "$exp"
            printf "${BLUE}│${WHITE} %-12s: ${RED}%-30s${BLUE}    │${NC}\n" "Status" "LOCKED"
            echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
            echo -e "${BLUE}│${WHITE}    Trojan account has been successfully locked${BLUE}  │${NC}"
            echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
            echo
            
            # Kirim log ke Telegram
            send_log
            
            echo -e "${CYAN}Press Enter to continue...${NC}"
            read -n 1 -s
        fi
    else
        display_header
        echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
        echo -e "${BLUE}│${WHITE}             ⚠️ ACCOUNT NOT FOUND${BLUE}                 │${NC}"
        echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
        printf "${BLUE}│${WHITE} %-12s: ${CYAN}%-30s${BLUE}    │${NC}\n" "Username" "$user"
        printf "${BLUE}│${WHITE} %-12s: ${RED}%-30s${BLUE}    │${NC}\n" "Status" "Account not found"
        echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
        echo
        echo -e "${CYAN}Press Enter to continue...${NC}"
        read -n 1 -s
    fi
fi