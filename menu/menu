#!/bin/bash

# ==================== KONFIGURASI WARNA ====================
REDBLD="\033[0m\033[91;1m"
Green="\e[92;1m"
RED="\033[1;31m"
YELLOW="\033[33;1m"
BLUE="\033[36;1m"
FONT="\033[0m"
NC='\e[0m'
CYAN="\033[96;1m"
WHITE="\033[97;1m"

# ==================== KONFIGURASI PATH ====================
ZIVPN_CONFIG="/etc/zivpn/config.json"
ZIVPN_USERS="/etc/zivpn/users.json"
ZIVPN_PORT=$(grep -oP '"listen":":\K[0-9]+' /etc/zivpn/config.json 2>/dev/null || echo "5667")
ZIVPN_API_PORT="8585"
API_KEY=$(cat /etc/zivpn/apikey 2>/dev/null)
GITHUB_REPO="https://raw.githubusercontent.com/rifg67/zivpn-rifts/main"
GITHUB_API_REPO="https://api.github.com/repos/rifg67/zivpn-rifts/contents/backup"
GITHUB_TOKEN_FILE="/etc/zivpn/github_token"
BACKUP_DIR="/root/zivpn_backups"

# ==================== AMBIL INFORMASI SISTEM ====================

RAM=$(free -m | awk 'NR==2 {print $2}')
MEMOFREE=$(printf '%-1s' "$(free -m | awk 'NR==2{printf "%.2f%%", $3*100/$2 }')")
LOADCPU=$(printf '%-0.00001s' "$(top -bn1 | awk '/Cpu/ { cpu = "" 100 - $8 "%" }; END { print cpu }')")
CPU=$(awk -F: '/model name/ {name=$2; exit} END {print name}' /proc/cpuinfo | sed 's/^ //')
CORES=$(awk -F: '/model name/ {c++} END {print c}' /proc/cpuinfo)
VENDOR=$(awk -F: '/vendor_id/ {vendor=$2; exit} END {print vendor}' /proc/cpuinfo | sed 's/^ //')
MYIP=$(curl -sS ipv4.icanhazip.com)
domain=$(cat /etc/zivpn/domain 2>/dev/null || echo "Tidak ada")
ISP=$(curl -s ipinfo.io/org 2>/dev/null | cut -d " " -f 2-10)
if [[ -z "$ISP" ]]; then ISP="Unknown"; fi
CITY=$(curl -s ipinfo.io/city 2>/dev/null)
if [[ -z "$CITY" ]]; then CITY="Unknown"; fi
MODEL=$(cat /etc/os-release | grep -w PRETTY_NAME | head -n1 | sed 's/=//g' | sed 's/"//g' | sed 's/PRETTY_NAME//g')
SERONLINE=$(uptime -p | cut -d " " -f 2-10000)

# ==================== FUNGSI CEK STATUS ====================
function check_zivpn_status() {
    if systemctl is-active --quiet zivpn 2>/dev/null; then
        echo -e "${Green}ON${NC}"
    else
        echo -e "${RED}OFF${NC}"
    fi
}

function check_api_status() {
    if systemctl is-active --quiet zivpn-api-js 2>/dev/null; then
        echo -e "${Green}ON${NC}"
    else
        echo -e "${RED}OFF${NC}"
    fi
}

function check_xray_status() {
    if systemctl is-active --quiet xray 2>/dev/null; then
        echo -e "${Green}ON${NC}"
    else
        echo -e "${RED}OFF${NC}"
    fi
}

function check_nginx_status() {
    if systemctl is-active --quiet nginx 2>/dev/null; then
        echo -e "${Green}ON${NC}"
    else
        echo -e "${RED}OFF${NC}"
    fi
}

# ==================== CEK IP & EXPIRED ====================
CEKIP() {
    IPLIST=$(curl -sS https://raw.githubusercontent.com/rifg67/script-rifts/main/ipx)
    IPVPS=$(echo "$IPLIST" | grep "$MYIP" | awk '{print $4}')
    USERNAME=$(echo "$IPLIST" | grep "$MYIP" | awk '{print $2}')
    EXPIRED=$(echo "$IPLIST" | grep "$MYIP" | awk '{print $3}')
    
    if [[ "$MYIP" != "$IPVPS" ]]; then
        clear
        echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
        echo -e "${BLUE}│${RED}              PERMISSION DENIED !${NC}"
        echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
        echo -e "${BLUE}│${NC}"
        echo -e "${BLUE}│${NC}  ${RED}IP Anda tidak terdaftar!${NC}"
        echo -e "${BLUE}│${NC}  ${YELLOW}Silakan hubungi admin untuk izin akses${NC}"
        echo -e "${BLUE}│${NC}"
        echo -e "${BLUE}│${NC}  ${CYAN}Telegram : https://t.me/PeyxDev${NC}"
        echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
        exit 1
    fi
    
    today=$(date -d "0 days" +%Y-%m-%d)
    d1=$(date -d "$EXPIRED" +%s 2>/dev/null)
    d2=$(date -d "$today" +%s)
    
    if [[ -z "$EXPIRED" ]]; then
        masaaktif="LIFETIME"
        status_exp="\033[92;1mActive\033[0m"
    elif [[ $d1 -lt $d2 ]]; then
        clear
        echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
        echo -e "${BLUE}│${RED}              ACCOUNT EXPIRED !${NC}"
        echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
        echo -e "${BLUE}│${NC}"
        echo -e "${BLUE}│${NC}  ${RED}Masa berlaku script Anda telah habis!${NC}"
        echo -e "${BLUE}│${NC}  ${YELLOW}Silakan perpanjang ke admin${NC}"
        echo -e "${BLUE}│${NC}"
        echo -e "${BLUE}│${NC}  ${CYAN}Telegram : https://t.me/PeyxDev${NC}"
        echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
        exit 1
    else
        certifacate=$(((d1 - d2) / 86400))
        masaaktif="${certifacate} Hari"
        status_exp="\033[92;1mActive\033[0m"
    fi
}

# ==================== MENU UTAMA ====================
function Zivpn_Banner() {
    clear
    echo -e "\033[36;1m┌─────────────────────────────────────────────────┐\033[0m"
    echo -e "\033[36;1m│\e[97m  \033[38;5;196m⁙\033[38;5;202m⁙\033[38;5;208m⁙\033[38;5;214m⁙\033[38;5;220m⁙\033[38;5;226m⁙\033[38;5;190m⁙\033[38;5;154m⁙\033[38;5;118m⁙\033[38;5;82m⁙\033[38;5;46m⁙\033[38;5;47m⁙\033[38;5;48m⁙\033[38;5;49m⁙\033[97m PEYX TUNNELING \033[38;5;87m⁙\033[38;5;86m⁙\033[38;5;85m⁙\033[38;5;84m⁙\033[38;5;83m⁙\033[38;5;44m⁙\033[38;5;43m⁙\033[38;5;42m⁙\033[38;5;41m⁙\033[38;5;40m⁙\033[38;5;39m⁙\033[38;5;38m⁙\033[38;5;37m⁙\033[38;5;36m⁙\033[97m   \033[36;1m│\033[0m"
    echo -e "\033[36;1m└─────────────────────────────────────────────────┘\033[0m"
}

function Service_System_Operating() {
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${WHITE} SYSTEM OS       : $MODEL ${NC}"
    echo -e "${BLUE}│${WHITE} CPU             : $VENDOR $CORES CORE \033[0m "
    echo -e "${BLUE}│${WHITE} SERVER RAM      : $(free -m | awk 'NR==2 {print $3}')/$RAM MB  \033[0m "
    echo -e "${BLUE}│${WHITE} UPTIME SERVER   : $SERONLINE \033[0m "
    echo -e "${BLUE}│${WHITE} IP VPS          : $MYIP ${NC}"
    echo -e "${BLUE}│${WHITE} ISP             : $ISP ${NC}"
    echo -e "${BLUE}│${WHITE} CITY            : $CITY ${NC}"
    echo -e "${BLUE}│${WHITE} DOMAIN          : $domain ${NC}"
    echo -e "${BLUE}│${WHITE} API KEY         : ${API_KEY}${NC}"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
}

function Service_Status() {
    if systemctl is-active --quiet zivpn 2>/dev/null; then
        ZIVPN_STATUS="ON"
        ZIVPN_COLOR="${Green}"
    else
        ZIVPN_STATUS="OFF"
        ZIVPN_COLOR="${RED}"
    fi
    
    if systemctl is-active --quiet zivpn-api-js 2>/dev/null; then
        API_STATUS="ON"
        API_COLOR="${Green}"
    else
        API_STATUS="OFF"
        API_COLOR="${RED}"
    fi
    
    if systemctl is-active --quiet xray 2>/dev/null; then
        XRAY_STATUS="ON"
        XRAY_COLOR="${Green}"
    else
        XRAY_STATUS="OFF"
        XRAY_COLOR="${RED}"
    fi
    
    if systemctl is-active --quiet nginx 2>/dev/null; then
        NGINX_STATUS="ON"
        NGINX_COLOR="${Green}"
    else
        NGINX_STATUS="OFF"
        NGINX_COLOR="${RED}"
    fi
    
    printf "${BLUE}┌─────────────────────────────────────────────────┐${NC}\n"
    printf "${BLUE}|  ${WHITE}ZIVPN:${NC} ${ZIVPN_COLOR}%-2s${NC} ${BLUE}|  ${WHITE}API:${NC} ${API_COLOR}%-2s${NC} ${BLUE}|  ${WHITE}XRAY:${NC} ${XRAY_COLOR}%-2s${NC} ${BLUE}|  ${WHITE}NGINX:${NC} ${NGINX_COLOR}%-2s${NC}  ${BLUE}|${NC}\n" "$ZIVPN_STATUS" "$API_STATUS" "$XRAY_STATUS" "$NGINX_STATUS"
    printf "${BLUE}└─────────────────────────────────────────────────┘${NC}\n"
}

function Details_Clients_Name() {
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${WHITE} CLIENTS    : ${USERNAME:-Unknown}${NC}"
    echo -e "${BLUE}│${WHITE} STATUS     : ${status_exp}${NC}"
    echo -e "${BLUE}│${WHITE} EXPIRY     : ${masaaktif}${NC}"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
}

Acces_Use_Command() {
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${GREEN}  [1]${WHITE} • Create Account     ${BLUE}  [6]${WHITE} • Private Bot   ${BLUE}│${NC}"
    echo -e "${BLUE}│${GREEN}  [2]${WHITE} • Restart Service    ${BLUE}  [7]${WHITE} • Change Limit  ${BLUE}│${NC}"
    echo -e "${BLUE}│${GREEN}  [3]${WHITE} • Service Status     ${BLUE}  [8]${WHITE} • Setting Bot   ${BLUE}│${NC}"
    echo -e "${BLUE}│${GREEN}  [4]${WHITE} • Backup & Restore   ${BLUE}  [9]${WHITE} • Exit          ${BLUE}│${NC}"
    echo -e "${BLUE}│${GREEN}  [5]${WHITE} • Update Script      ${BLUE}                      ${BLUE}│${NC}"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
}

# ==================== SELECTOR / NAVIGASI ====================
function Select_Display() {
    while true; do
        Zivpn_Banner
        Service_System_Operating
        Service_Status
        Details_Clients_Name
        Acces_Use_Command
        echo
        read -p "   Pilih menu : " menu
        
        case $menu in
            1)
                clear
                if [ -f /usr/local/bin/m-create ]; then
                    m-create
                else
                    echo -e "${RED}❌ Script m-create tidak ditemukan!${NC}"
                    sleep 2
                fi
                ;;
            2) restart ;;
            3) status-services ;;
            4) m-backup ;;
            5) wget -q https://raw.githubusercontent.com/rifg67/zivpn-rifts/main/update.sh && chmod +x update.sh && ./update.sh ;;
            6) install-bot ;;
            7) install-bot-seller ;;
            8) change-limit ;;
            9) install-bot ;;
            0|00) 
                clear
                exit 0 
                ;;
            *) 
                echo -e "${RED}   Pilihan salah!${NC}"
                sleep 1
                ;;
        esac
        clear
    done
}

# ==================== MAIN ====================
CEKIP
Select_Display