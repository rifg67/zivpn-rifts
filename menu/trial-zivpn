#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BG_GREEN='\033[42;1m'
NC='\033[0m'

SPINNER=("⣷" "⣯" "⣟" "⡿" "⢿" "⣻" "⣽" "⣾")

ZIVPN_CONFIG="/etc/zivpn/config.json"
ZIVPN_USERS="/etc/zivpn/users.json"
domain=$(cat /etc/zivpn/domain 2>/dev/null || echo "Tidak ada")

display_header() {
    clear
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${YELLOW}    ╔═══════════════════════════════════════╗${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║        ⏱️ TRIAL ZIVPN USER             ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║          Premium Edition              ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ╚═══════════════════════════════════════╝${BLUE}    │${NC}"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
    echo
}

show_loading() {
    local text=$1
    echo -ne "${CYAN}${text} ${NC}"
    for i in {1..3}; do
        for char in "${SPINNER[@]}"; do
            echo -ne "\r${CYAN}${text} $char ${NC}"
            sleep 0.1
        done
    done
    echo -ne "\r${GREEN}${text} ✓ ${NC}"
    echo
}

generate_random_password() {
    echo $(openssl rand -hex 8)
}

send_telegram_notification() {
    local action="$1"
    local username="$2"
    local expired="$3"
    local iplimit="$4"
    local domain_info="$5"
    
    local bot_config="/etc/zivpn/bot-config.json"
    
    if [ ! -f "$bot_config" ]; then
        return 1
    fi
    
    local bot_token=$(grep -o '"bot_token": "[^"]*"' "$bot_config" | cut -d'"' -f4)
    local admin_id=$(grep -o '"admin_id": [0-9]*' "$bot_config" | cut -d' ' -f2)
    
    if [ -z "$bot_token" ] || [ -z "$admin_id" ]; then
        return 1
    fi
    
    local clean_username=$(echo "$username" | sed 's/\x1b\[[0-9;]*m//g')
    local clean_expired=$(echo "$expired" | sed 's/\x1b\[[0-9;]*m//g')
    local datetime_now=$(date '+%Y-%m-%d %H:%M:%S')
    
    local message="⏱️ *TRIAL USER CREATED* ⏱️
━━━━━━━━━━━━━━━━━━━━
👤 *Password:* \`$clean_username\`
⏰ *Expired:* $clean_expired (30 minutes)
🌐 *IP Limit:* 1
🏷️ *Domain:* \`$domain_info\`
⏰ *Time:* $datetime_now
━━━━━━━━━━━━━━━━━━━━
🎫 Trial user will expire in 30 minutes!"
    
    local url="https://api.telegram.org/bot${bot_token}/sendMessage"
    curl -s -X POST "$url" -d "chat_id=${admin_id}" -d "text=${message}" -d "parse_mode=Markdown" >/dev/null
}

Trial_ZiVPN_User() {
    display_header
    
    echo -e "\n${BG_GREEN}${WHITE} TRIAL ZIVPN ACCOUNT (30 MENIT) ${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    echo
    
    password=$(generate_random_password)
    echo -e "${CYAN}╭─ AUTO GENERATED PASSWORD ${NC}"
    echo -e "${CYAN}╰────────────────────────────────────────────────${NC}"
    echo -e "${WHITE}Password Auto    ${WHITE}: ${GREEN}$password${NC}"
    echo
    
    show_loading "Creating trial ZiVPN account (30 minutes)"
    
    trial_end=$(date -d "+30 minutes" +"%Y-%m-%d %H:%M:%S")
    trial_date=$(date -d "+30 minutes" +"%Y-%m-%d")
    tgl=$(date -d "+30 minutes" +"%d")
    bln=$(date -d "+30 minutes" +"%b")
    thn=$(date -d "+30 minutes" +"%Y")
    expe="$tgl $bln, $thn - 30 Menit"
    tgl2=$(date +"%d")
    bln2=$(date +"%b")
    thn2=$(date +"%Y")
    tnggl="$tgl2 $bln2, $thn2"
    
    python3 << PYTHON
import json
with open("$ZIVPN_CONFIG", "r") as f:
    config = json.load(f)
if "$password" not in config["auth"]["config"]:
    config["auth"]["config"].append("$password")
with open("$ZIVPN_CONFIG", "w") as f:
    json.dump(config, f, indent=4)

try:
    with open("$ZIVPN_USERS", "r") as f:
        users = json.load(f)
except:
    users = []

users.append({
    "password": "$password",
    "expired": "$trial_date",
    "expired_time": "$trial_end",
    "ip_limit": 1,
    "status": "active",
    "is_trial": True,
    "created_at": "$(date '+%Y-%m-%d %H:%M:%S')"
})
with open("$ZIVPN_USERS", "w") as f:
    json.dump(users, f, indent=4)
PYTHON
    
    show_loading "Restarting service"
    systemctl restart zivpn 2>/dev/null
    
    show_loading "Sending Telegram notification"
    send_telegram_notification "trial" "$password" "$trial_end" "1" "$domain"
    
    # Auto delete after 30 minutes
    (
        sleep 1800
        python3 << PYTHON
import json
with open("$ZIVPN_CONFIG", "r") as f:
    config = json.load(f)
if "$password" in config["auth"]["config"]:
    config["auth"]["config"].remove("$password")
with open("$ZIVPN_CONFIG", "w") as f:
    json.dump(config, f, indent=4)

with open("$ZIVPN_USERS", "r") as f:
    users = json.load(f)
users = [u for u in users if u.get("password") != "$password"]
with open("$ZIVPN_USERS", "w") as f:
    json.dump(users, f, indent=4)
PYTHON
        systemctl restart zivpn 2>/dev/null
    ) &
    
    clear
    
    echo -e "\n${GREEN}✅ Trial ZiVPN Account Created Successfully!${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    echo -e "${WHITE}              ACCOUNT DETAILS${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    echo -e "${CYAN}Password         ${WHITE}: ${GREEN}$password${NC}"
    echo -e "${CYAN}Duration         ${WHITE}: ${YELLOW}30 Minutes${NC}"
    echo -e "${CYAN}IP Limit         ${WHITE}: ${YELLOW}1 Device(s)${NC}"
    echo -e "${CYAN}Domain           ${WHITE}: ${GREEN}$domain${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    
    echo -e "\n${WHITE}            EXPIRY INFO${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    echo -e "${CYAN}Created          ${WHITE}: ${GREEN}$tnggl${NC}"
    echo -e "${CYAN}Expires          ${WHITE}: ${YELLOW}$trial_end${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    
    echo -e "\n${YELLOW}⚠️ Trial account will expire in 30 minutes!${NC}"
    
    echo -e "\n${BLUE}─────────────────────────────────────────────────${NC}"
    echo -e "${PURPLE}              Script By PeyxDev${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    
    echo -e "\n${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
}

Trial_ZiVPN_User