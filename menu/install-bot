#!/bin/bash

# Color Definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BG_GREEN='\033[42;1m'
BG_RED='\033[41;1m'
NC='\033[0m'

SPINNER=("вЈ·" "вЈҜ" "вЈҹ" "вЎҝ" "вўҝ" "вЈ»" "вЈҪ" "вЈҫ")

# Konfigurasi
BOT_CONFIG="/etc/zivpn/bot-config.json"
BOT_DIR="/etc/zivpn/bot"
API_URL="http://localhost:8585"
GITHUB_REPO="https://raw.githubusercontent.com/rifg67/zivpn-rifts/main/bot"
domain=$(cat /etc/zivpn/domain 2>/dev/null || echo "Tidak ada")

display_header() {
    clear
    echo -e "${BLUE}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
    echo -e "${BLUE}в”Ӯ${YELLOW}    в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—${BLUE}    в”Ӯ${NC}"
    echo -e "${BLUE}в”Ӯ${YELLOW}    в•‘       рҹӨ– INSTALL TELEGRAM BOT           в•‘${BLUE}    в”Ӯ${NC}"
    echo -e "${BLUE}в”Ӯ${YELLOW}    в•‘       Modern Bot Manager               в•‘${BLUE}    в”Ӯ${NC}"
    echo -e "${BLUE}в”Ӯ${YELLOW}    в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ${BLUE}    в”Ӯ${NC}"
    echo -e "${BLUE}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}"
    echo
}

show_loading() {
    local text=$1
    echo -ne "${CYAN}${text} ${NC}"
    for i in {1..3}; do
        for char in "${SPINNER[@]}"; do
            echo -ne "\r${CYAN}${text} $char ${NC}"
            sleep 0.1
        done
    done
    echo -ne "\r${GREEN}${text} вң“ ${NC}"
    echo
}

# Test koneksi ke bot
test_bot_connection() {
    local bot_token=$1
    local admin_id=$2
    
    echo ""
    show_loading "Testing bot connection"
    
    local url="https://api.telegram.org/bot${bot_token}/getMe"
    local response=$(curl -s "$url")
    
    if echo "$response" | grep -q '"ok":true'; then
        echo -e "\n${GREEN}вң… Bot token valid!${NC}"
        
        # Test send message
        local test_url="https://api.telegram.org/bot${bot_token}/sendMessage"
        local test_msg="вң… *ZiVPN Bot Installed Successfully!*\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nрҹӨ– *Bot is now active*\nрҹҸ·пёҸ *Domain:* $domain\nвҸ° *Time:* $(date '+%Y-%m-%d %H:%M:%S')\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nрҹ“Ң *Use /start to begin*"
        
        curl -s -X POST "$test_url" \
            -d "chat_id=${admin_id}" \
            -d "text=${test_msg}" \
            -d "parse_mode=Markdown" > /dev/null
        
        echo -e "${GREEN}вң… Test message sent to admin${NC}"
        return 0
    else
        echo -e "\n${RED}вқҢ Invalid bot token!${NC}"
        return 1
    fi
}

# Simpan konfigurasi ke file
save_config() {
    local bot_token=$1
    local admin_id=$2
    
    mkdir -p /etc/zivpn
    
    cat > "$BOT_CONFIG" << EOF
{
    "bot_token": "$bot_token",
    "admin_id": $admin_id,
    "domain": "$domain",
    "api_url": "$API_URL",
    "notifications": {
        "create": true,
        "delete": true,
        "renew": true,
        "trial": true,
        "backup": true,
        "restore": true
    }
}
EOF
    
    chmod 600 "$BOT_CONFIG"
    echo -e "${GREEN}вң… Config saved to $BOT_CONFIG${NC}"
}

restart_all_services() {
    echo ""
    echo -e "${YELLOW}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${NC}"
    echo -e "${CYAN}рҹ”„ Restarting All Services...${NC}"
    echo -e "${YELLOW}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${NC}"
    
    # Stop semua service
    echo -e "${PURPLE}вһӨ Stopping all services...${NC}"
    systemctl stop zivpn zivpn-api-js zivpn-bot 2>/dev/null
    pkill -9 -f node 2>/dev/null
    sleep 2
    echo -e "${GREEN}  вң“ All services stopped${NC}"
    
    # Start ulang services
    echo -e "${PURPLE}вһӨ Starting services...${NC}"
    echo -e "${CYAN}  вҖў Starting zivpn...${NC}"
    systemctl start zivpn
    sleep 2
    echo -e "${GREEN}    вң“ zivpn started${NC}"
    
    echo -e "${CYAN}  вҖў Starting zivpn-api-js...${NC}"
    systemctl start zivpn-api-js
    sleep 2
    echo -e "${GREEN}    вң“ zivpn-api-js started${NC}"
    
    echo -e "${CYAN}  вҖў Starting zivpn-bot...${NC}"
    systemctl start zivpn-bot
    sleep 2
    echo -e "${GREEN}    вң“ zivpn-bot started${NC}"
    
    # Cek status semua services
    echo ""
    echo -e "${YELLOW}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${NC}"
    echo -e "${CYAN}рҹ“Ҡ Service Status${NC}"
    echo -e "${YELLOW}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${NC}"
    
    for service in zivpn zivpn-api-js zivpn-bot; do
        if systemctl is-active --quiet $service; then
            echo -e "${GREEN}вң… $service is running${NC}"
        else
            echo -e "${RED}вқҢ $service is not running${NC}"
        fi
    done
    
    echo -e "${YELLOW}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${NC}"
    echo ""
    
    # Tampilkan detailed status
    echo -e "${CYAN}рҹ“Ӣ Detailed Status:${NC}"
    systemctl status zivpn zivpn-api-js zivpn-bot --no-pager | grep -E "Loaded:|Active:|Main PID:" | sed 's/^/  /'
    echo ""
}

Install_Bot() {
    display_header
    
    echo -e "\n${BG_GREEN}${WHITE} INSTALL TELEGRAM BOT ${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    echo ""
    
    # Cek Node.js
    if ! command -v node &> /dev/null; then
        echo -e "${YELLOW}вҡ  Node.js not installed! Installing...${NC}"
        show_loading "Installing Node.js 20.x"
        curl -fsSL https://deb.nodesource.com/setup_20.x | bash - &>/dev/null
        apt-get install -y nodejs &>/dev/null
        echo -e "\r${GREEN}вң“ Installing Node.js 20.x      "
    fi
    
    # Cek 7zip
    if ! command -v 7z &> /dev/null; then
        show_loading "Installing p7zip"
        apt-get install -y p7zip-full &>/dev/null
        echo -e "\r${GREEN}вң“ Installing p7zip-full      "
    fi
    
    # Cek apakah sudah terinstall
    if [ -f "/etc/systemd/system/zivpn-bot.service" ]; then
        echo -e "${YELLOW}вҡ  Bot already installed!${NC}"
        echo -ne "${PURPLE}вһӨ Reinstall? (y/n): ${NC}"
        read reinstall
        if [[ "$reinstall" != "y" ]]; then
            echo ""
            read -p "   Press Enter to continue..."
            return 0
        fi
        systemctl stop zivpn-bot 2>/dev/null
        systemctl disable zivpn-bot 2>/dev/null
        rm -f /etc/systemd/system/zivpn-bot.service
    fi
    
    echo -e "${CYAN}в•ӯв”Җ BOT CONFIGURATION ${NC}"
    echo -e "${CYAN}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    echo -e "${WHITE}How to get Bot Token:${NC}"
    echo -e "  1. Open Telegram and search @BotFather"
    echo -e "  2. Send /newbot and follow instructions"
    echo -e "  3. Copy the API token"
    echo ""
    echo -e "${WHITE}How to get Admin ID:${NC}"
    echo -e "  1. Open Telegram and search @userinfobot"
    echo -e "  2. Send /start"
    echo -e "  3. Copy your ID"
    echo ""
    
    echo -ne "${PURPLE}вһӨ Bot Token: ${NC}"
    read bot_token
    
    echo -ne "${PURPLE}вһӨ Admin ID: ${NC}"
    read admin_id
    
    if [[ -z "$bot_token" ]] || [[ -z "$admin_id" ]]; then
        echo -e "\n${RED}вқҢ Error: Bot Token dan Admin ID harus diisi!${NC}"
        sleep 2
        return 1
    fi
    
    # Test koneksi
    if ! test_bot_connection "$bot_token" "$admin_id"; then
        echo -e "\n${RED}вқҢ Bot connection failed! Please check your token and ID${NC}"
        sleep 2
        return 1
    fi
    
    # Simpan konfigurasi
    show_loading "Saving configuration"
    save_config "$bot_token" "$admin_id"
    
    # Buat direktori bot
    mkdir -p "$BOT_DIR"
    
    # Download bot.zip
    show_loading "Downloading bot.zip"
    wget -q ${GITHUB_REPO}/bot.zip -O ${BOT_DIR}/bot.zip 2>/dev/null
    
    if [ ! -f "${BOT_DIR}/bot.zip" ]; then
        echo -e "\n${RED}вқҢ Failed to download bot.zip!${NC}"
        echo -e "${YELLOW}Please ensure the file exists at: ${GITHUB_REPO}/bot.zip${NC}"
        return 1
    fi
    echo -e "\n${GREEN}вң… bot.zip downloaded successfully${NC}"
    
    # Extract zip dengan password
    show_loading "Extracting bot.zip with password"
    cd "$BOT_DIR"
    7z x bot.zip -p"rifgan67" -y > /dev/null 2>&1
    
    if [ $? -ne 0 ]; then
        echo -e "\n${RED}вқҢ Failed to extract bot.zip! Wrong password or corrupted file${NC}"
        return 1
    fi
    echo -e "\n${GREEN}вң… bot.zip extracted successfully${NC}"
    
    # Hapus file zip setelah extract
    rm -f ${BOT_DIR}/bot.zip
    echo -e "${GREEN}вң… Cleaned up zip file${NC}"
    
    # Cek apakah bot.js ada setelah extract
    if [ ! -f "${BOT_DIR}/bot.js" ]; then
        echo -e "\n${RED}вқҢ bot.js not found after extraction!${NC}"
        echo -e "${YELLOW}Please check the contents of your zip file${NC}"
        return 1
    fi
    
    # Install dependencies
    cd "$BOT_DIR"
    show_loading "Installing dependencies"
    npm install node-telegram-bot-api axios &>/dev/null
    
    # Create systemd service
    show_loading "Creating systemd service"
    cat > /etc/systemd/system/zivpn-bot.service << EOF
[Unit]
Description=ZiVPN Telegram Bot Service
After=network.target zivpn-api-js.service

[Service]
Type=simple
User=root
WorkingDirectory=${BOT_DIR}
ExecStart=/usr/bin/node ${BOT_DIR}/bot.js
Restart=always
RestartSec=3
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
EOF
    
    # Start service
    show_loading "Starting bot service"
    systemctl daemon-reload
    systemctl enable zivpn-bot
    systemctl start zivpn-bot
    
    sleep 2
    
    clear
    
    echo -e "\n${GREEN}вң… Bot installed successfully!${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    echo -e "${CYAN}Bot Token        ${WHITE}: ${GREEN}${bot_token}${NC}"
    echo -e "${CYAN}Admin ID         ${WHITE}: ${GREEN}${admin_id}${NC}"
    echo -e "${CYAN}Config File      ${WHITE}: ${GREEN}${BOT_CONFIG}${NC}"
    echo -e "${CYAN}Bot Script       ${WHITE}: ${GREEN}${BOT_DIR}/bot.js${NC}"
    echo -e "${CYAN}Service Name     ${WHITE}: ${GREEN}zivpn-bot${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    
    # Restart all services
    restart_all_services
    
    echo -e "${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
}

Install_Bot