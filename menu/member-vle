#!/bin/bash

# Color Definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'
BOLD='\033[1m'

nama=$(cat /etc/zivpn/username 2>/dev/null || echo "PEYX TUNNEL")

clear
echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
echo -e "${BLUE}│${YELLOW}        ╔═══════════════════════════╗${BLUE}            │${NC}"
echo -e "${BLUE}│${YELLOW}        ║     👥 LIST MEMBER VLESS  ║${BLUE}            │${NC}"
echo -e "${BLUE}│${YELLOW}        ║       Premium Edition     ║${BLUE}            │${NC}"
echo -e "${BLUE}│${YELLOW}        ╚═══════════════════════════╝${BLUE}            │${NC}"
echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
echo

echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
echo -e "${BLUE}│${WHITE}             📊 VLESS ACCOUNT LIST${BLUE}               │${NC}"
echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
echo -e "${BLUE}│${WHITE}  USERNAME         EXP DATE         STATUS${BLUE}       │${NC}"
echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"

# Menampilkan data Vless dari database /etc/peyx/vless.db
if [ -f "/etc/peyx/vless.db" ]; then
    while IFS= read -r line; do
        if [[ "$line" =~ ^### ]]; then
            username=$(echo "$line" | awk '{print $2}')
            exp_date=$(echo "$line" | awk '{print $3}')
            if [ ! -z "$username" ] && [ ! -z "$exp_date" ]; then
                printf "${BLUE}│${WHITE}  %-15s %-15s ${GREEN}%-10s${WHITE}     ${BLUE}│${NC}\n" "$username" "$exp_date" "ACTIVE"
            fi
        fi
    done < /etc/peyx/vless.db
else
    echo -e "${BLUE}│${WHITE}  No accounts found${NC}${BLUE}                                   │${NC}"
fi

# Hitung jumlah akun Vless
if [ -f "/etc/peyx/vless.db" ]; then
    JUMLAH=$(grep -c "^###" /etc/peyx/vless.db)
else
    JUMLAH=0
fi

echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
printf "${BLUE}│${WHITE} %-16s: ${GREEN}%-26s${BLUE}    │${NC}\n" "Total Accounts" "$JUMLAH users"
echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
echo
echo -e "${CYAN}Press Enter to continue...${NC}"
read -n 1 -s

clear
echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
echo -e "${BLUE}│${PURPLE}          Terimakasih Telah Menggunakan${BLUE}          │${NC}"
echo -e "${BLUE}│${PURPLE}                  Script Credit${BLUE}                  │${NC}"
echo -e "${BLUE}│${PURPLE}                     $nama${BLUE}                  │${NC}"
echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"