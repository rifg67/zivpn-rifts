#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BG_RED='\033[41;1m'
NC='\033[0m'

SPINNER=("⣷" "⣯" "⣟" "⡿" "⢿" "⣻" "⣽" "⣾")

GITHUB_TOKEN_FILE="/etc/zivpn/github_token"

display_header() {
    clear
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${YELLOW}    ╔═══════════════════════════════════════╗${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║       🗑️ HAPUS GITHUB TOKEN           ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║       Premium Edition                 ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ╚═══════════════════════════════════════╝${BLUE}    │${NC}"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
    echo
}

show_loading() {
    local text=$1
    echo -ne "${CYAN}${text} ${NC}"
    for i in {1..3}; do
        for char in "${SPINNER[@]}"; do
            echo -ne "\r${CYAN}${text} $char ${NC}"
            sleep 0.1
        done
    done
    echo -ne "\r${GREEN}${text} ✓ ${NC}"
    echo
}

Delete_Token() {
    display_header
    
    echo -e "\n${BG_RED}${WHITE} HAPUS GITHUB TOKEN ${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    echo
    
    if [ ! -f "$GITHUB_TOKEN_FILE" ]; then
        echo -e "${YELLOW}⚠ Tidak ada token yang tersimpan.${NC}"
        echo -e "\n${CYAN}Press Enter to continue...${NC}"
        read -n 1 -s
        return 0
    fi
    
    current_token=$(cat "$GITHUB_TOKEN_FILE")
    echo -e "${CYAN}╭─ CURRENT TOKEN ${NC}"
    echo -e "${CYAN}╰────────────────────────────────────────────────${NC}"
    echo -e "${WHITE}Token saat ini  ${WHITE}: ${YELLOW}${current_token:0:15}...${current_token: -15}${NC}"
    echo
    
    echo -e "${RED}⚠️  PERINGATAN: Menghapus token akan membuat fitur backup upload tidak berfungsi!${NC}"
    echo ""
    echo -ne "${PURPLE}➤ Yakin ingin menghapus token? (y/n): ${NC}"
    read confirm
    
    if [[ "$confirm" == "y" ]]; then
        show_loading "Deleting token"
        
        # Backup token yang dihapus
        echo "# Token dihapus pada $(date '+%Y-%m-%d %H:%M:%S')" >> "${GITHUB_TOKEN_FILE}.deleted"
        echo "$current_token" >> "${GITHUB_TOKEN_FILE}.deleted"
        
        rm -f "$GITHUB_TOKEN_FILE"
        
        clear
        
        echo -e "\n${GREEN}✅ Token berhasil dihapus!${NC}"
        echo -e "${YELLOW}📌 Anda dapat mengatur token baru melalui Menu GitHub Token${NC}"
    else
        echo -e "\n${YELLOW}⚠ Penghapusan dibatalkan.${NC}"
    fi
    
    echo -e "\n${BLUE}─────────────────────────────────────────────────${NC}"
    echo -e "${PURPLE}              Script By PeyxDev${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    
    echo -e "\n${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
}

Delete_Token