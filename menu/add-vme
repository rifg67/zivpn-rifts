#!/bin/bash

# Color Definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BG_BLUE='\033[44;1m'
BG_GREEN='\033[42;1m'
BG_RED='\033[41;1m'
NC='\033[0m'
BOLD='\033[1m'

# Function to display header
display_header() {
    clear
    echo -e "${BLUE}┌─────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${YELLOW}    ╔═══════════════════════╗${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║   🚀 CREATE VMESS     ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║   Premium Edition     ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ╚═══════════════════════╝${BLUE}    │${NC}"
    echo -e "${BLUE}└─────────────────────────────────┘${NC}"
    echo
}

# Get system information
ISP=$(curl -s ipinfo.io/org | cut -d " " -f 2-10 2>/dev/null || echo "Unknown ISP")
CITY=$(curl -s ipinfo.io/city 2>/dev/null || echo "Unknown City")
domain=$(cat /etc/zivpn/domain 2>/dev/null || echo "example.com")
nama=$(cat /etc/zivpn/username 2>/dev/null || echo "PEYX TUNNEL")
IP=$(curl -sS ipv4.icanhazip.com 2>/dev/null || echo "Unknown IP")

# ==================== BOT CONFIGURATION (DARI /etc/zivpn/bot-config.json) ====================
BOT_CONFIG="/etc/zivpn/bot-config.json"

# Ambil bot token dan chat id dari file JSON
get_bot_config() {
    if [ -f "$BOT_CONFIG" ]; then
        KEY=$(grep -o '"bot_token": "[^"]*"' "$BOT_CONFIG" | cut -d'"' -f4)
        CHATIDS=$(grep -o '"admin_id": [0-9]*' "$BOT_CONFIG" | cut -d' ' -f2)
        echo "$KEY|$CHATIDS"
    else
        echo "|"
    fi
}

BOT_INFO=$(get_bot_config)
KEY=$(echo "$BOT_INFO" | cut -d'|' -f1)
CHATIDS=$(echo "$BOT_INFO" | cut -d'|' -f2)
TIME="10"
URL="https://api.telegram.org/bot$KEY/sendMessage"

# Transaction bot (gunakan bot yang sama atau file terpisah)
# Jika ada file terpisah untuk transaksi, bisa disesuaikan
KEY2="$KEY"
CHATID2="$CHATIDS"
URL2="https://api.telegram.org/bot$KEY2/sendMessage"

# Function to install VMess monitoring cron job
install_vmess_monitoring_cron() {
    cat > /usr/local/bin/vmess_monitor.sh << 'EOF'
#!/bin/bash

# Configuration - ambil dari /etc/zivpn/bot-config.json
BOT_CONFIG="/etc/zivpn/bot-config.json"
if [ -f "$BOT_CONFIG" ]; then
    KEY=$(grep -o '"bot_token": "[^"]*"' "$BOT_CONFIG" | cut -d'"' -f4)
    CHATIDS=$(grep -o '"admin_id": [0-9]*' "$BOT_CONFIG" | cut -d' ' -f2)
else
    KEY=""
    CHATIDS=""
fi
TIME="10"
URL="https://api.telegram.org/bot$KEY/sendMessage"

get_vmess_connections() {
    local username=$1
    local connections=$(tail -n 100 /var/log/xray/access.log 2>/dev/null | grep "accepted" | grep "vmess" | grep "$username" | awk '{print $3}' | sort | uniq | wc -l)
    echo $connections
}

get_vmess_connected_ips() {
    local username=$1
    tail -n 100 /var/log/xray/access.log 2>/dev/null | grep "accepted" | grep "vmess" | grep "$username" | awk '{print $3}' | sort | uniq | tr '\n' ', ' | sed 's/, $//'
}

tail -n 50 /var/log/xray/access.log 2>/dev/null | grep "accepted" | grep "vmess" | while read line; do
    if [[ $line =~ accepted.*vmess.*email:\ ([^ ]+) ]]; then
        username="${BASH_REMATCH[1]}"
        client_ip=$(echo "$line" | awk '{print $3}')
        
        if [ -f "/etc/peyx/limit/vmess/ip/$username" ]; then
            ip_limit=$(cat "/etc/peyx/limit/vmess/ip/$username" 2>/dev/null)
            
            if [ "$ip_limit" -gt 0 ]; then
                sleep 2
                current_connections=$(get_vmess_connections "$username")
                connected_ips=$(get_vmess_connected_ips "$username")
                
                if [ "$current_connections" -gt "$ip_limit" ]; then
                    TEXT="
<code>------------------------------</code>
<b>⚠️ VMESS IP LIMIT EXCEEDED</b>
<code>------------------------------</code>
<code>Username      : $username</code>
<code>Current IPs   : $current_connections</code>
<code>Allowed IPs   : $ip_limit</code>
<code>Client IP     : $client_ip</code>
<code>All IPs       : $connected_ips</code>
<code>Time          : $(date)</code>
<code>------------------------------</code>"
                    
                    for CHATID in $CHATIDS; do
                        curl -s --max-time "$TIME" -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" "$URL" >/dev/null
                    done
                    echo "$(date): VMess IP Limit Exceeded - User: $username" >> /var/log/vmess_ip_limit.log
                fi
            fi
        fi
    fi
done

if [ "$(date +%M)" = "00" ]; then
    today=$(date +"%Y-%m-%d")
    if [ -f "/etc/peyx/vmess.db" ]; then
        while IFS= read -r line; do
            if [[ "$line" =~ ^###[[:space:]]+([^[:space:]]+)[[:space:]]+([^[:space:]]+)[[:space:]]+([^[:space:]]+)[[:space:]]+([^[:space:]]+)[[:space:]]+([^[:space:]]+) ]]; then
                username="${BASH_REMATCH[1]}"
                expire_date="${BASH_REMATCH[2]}"
                
                if [ "$expire_date" = "$today" ]; then
                    TEXT="
<code>------------------------------</code>
<b>🔔 VMESS ACCOUNT EXPIRED</b>
<code>------------------------------</code>
<code>Username      : $username</code>
<code>Status        : EXPIRED TODAY</code>
<code>Expiry Date   : $expire_date</code>
<code>Time          : $(date)</code>
<code>------------------------------</code>"
                    
                    for CHATID in $CHATIDS; do
                        curl -s --max-time "$TIME" -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" "$URL" >/dev/null
                    done
                    echo "$(date): VMess Account Expired - User: $username" >> /var/log/vmess_expiry.log
                fi
            fi
        done < /etc/peyx/vmess.db
    fi
fi
EOF

    chmod +x /usr/local/bin/vmess_monitor.sh
    (crontab -l 2>/dev/null | grep -v "/usr/local/bin/vmess_monitor.sh"; echo "* * * * * /usr/local/bin/vmess_monitor.sh") | crontab -
    touch /var/log/vmess_ip_limit.log /var/log/vmess_expiry.log
    chmod 644 /var/log/vmess_ip_limit.log /var/log/vmess_expiry.log
}

# Function to send Telegram notification (HTML format)
send_telegram_notification() {
    local message="$1"
    local is_transaction="$2"
    
    local target_chatid="$CHATIDS"
    local target_url="$URL"
    
    if [ "$is_transaction" = "true" ]; then
        target_chatid="$CHATID2"
        target_url="$URL2"
    fi
    
    if [ -n "$target_chatid" ] && [ -n "$KEY" ]; then
        curl -s --max-time "$TIME" -X POST "$target_url" \
            -d "chat_id=${target_chatid}" \
            -d "disable_web_page_preview=1" \
            -d "parse_mode=html" \
            --data-urlencode "text=${message}" >/dev/null
    fi
}

# Function to create VMess account
Create_VMess_Account() {
    display_header
    echo -e "\n${BG_GREEN}${WHITE} CREATE VMESS ACCOUNT ${NC}"
    echo -e "${BLUE}──────────────────────────${NC}"
    echo
    
    echo -e "${CYAN}Installing monitoring service...${NC}"
    install_vmess_monitoring_cron
    echo -e "${GREEN}✓ Monitoring service installed${NC}"
    
    echo -e "${CYAN}╭─ ACCOUNT DETAILS ${NC}"
    echo -e "${CYAN}╰──────────────────${NC}"
    echo -e "${WHITE}Enter account information${NC}"
    
    # Username input
    while true; do
        echo -ne "${PURPLE}➤ Username: ${NC}"
        read user
        
        if [[ -z "$user" ]]; then
            echo -e "${RED}❌ Error: Username cannot be empty!${NC}"
            continue
        fi
        
        if grep -q "### $user" /etc/peyx/vmess.db 2>/dev/null; then
            echo -e "${RED}❌ Error: Username already exists!${NC}"
            continue
        fi
        break
    done
    
    # UUID input
    echo -ne "${PURPLE}➤ Custom UUID (press enter for random): ${NC}"
    read uuid_input
    if [[ -z $uuid_input ]]; then
        uuid=$(cat /proc/sys/kernel/random/uuid)
    else
        uuid=$uuid_input
    fi
    
    echo -e "\n${YELLOW}Note: Enter 0 for unlimited${NC}"
    echo -ne "${PURPLE}➤ Quota (GB): ${NC}"
    read Quota
    [[ -z "$Quota" ]] && Quota=0
    
    echo -ne "${PURPLE}➤ Limit IP: ${NC}"
    read iplimit
    [[ -z "$iplimit" ]] && iplimit=0
    
    echo -ne "${PURPLE}➤ Duration (days): ${NC}"
    read masaaktif
    
    if ! [[ "$masaaktif" =~ ^[0-9]+$ ]] || [ "$masaaktif" -lt 1 ]; then
        echo -e "\n${RED}❌ Error: Please enter valid days!${NC}"
        sleep 2
        return 1
    fi
    
    echo -e "${CYAN}Creating VMess account...${NC}"
    
    # Set dates
    exp=$(date -d "$masaaktif days" +"%Y-%m-%d")
    expe=$(date -d "$masaaktif days" +"%d %b %Y")
    tnggl=$(date +"%d %b %Y")
    
    # ==================== TAMBAH USER KE XRAY (PAKAI JQ) ====================
    echo -e "${CYAN}Adding user to Xray config...${NC}"
    
    if ! grep -q '"protocol": "vmess"' /usr/local/etc/xray/config.json; then
        echo -e "${RED}❌ Error: VMess inbound not found in config!${NC}"
        return 1
    fi
    
    jq --arg uuid "$uuid" --arg user "$user" \
       '.inbounds |= map(if .protocol == "vmess" then 
           .settings.clients += [{"id": $uuid, "alterId": 0, "email": $user}] 
       else . end)' /usr/local/etc/xray/config.json > /usr/local/etc/xray/config.json.tmp && \
       mv /usr/local/etc/xray/config.json.tmp /usr/local/etc/xray/config.json
    
    if [ $? -ne 0 ]; then
        echo -e "${RED}❌ Error: Failed to add user to config!${NC}"
        return 1
    fi
    
    systemctl restart xray
    
    # Create VMess links
    vmess_tls="vmess://$(echo -n "{\"v\":\"2\",\"ps\":\"$user\",\"add\":\"$domain\",\"port\":\"443\",\"id\":\"$uuid\",\"aid\":\"0\",\"net\":\"ws\",\"path\":\"/vmess\",\"host\":\"$domain\",\"tls\":\"tls\"}" | base64 -w 0)"
    vmess_http="vmess://$(echo -n "{\"v\":\"2\",\"ps\":\"$user\",\"add\":\"$domain\",\"port\":\"80\",\"id\":\"$uuid\",\"aid\":\"0\",\"net\":\"ws\",\"path\":\"/vmess\",\"host\":\"$domain\",\"tls\":\"none\"}" | base64 -w 0)"
    vmess_grpc="vmess://$(echo -n "{\"v\":\"2\",\"ps\":\"$user\",\"add\":\"$domain\",\"port\":\"443\",\"id\":\"$uuid\",\"aid\":\"0\",\"net\":\"grpc\",\"path\":\"vmess-grpc\",\"host\":\"$domain\",\"tls\":\"tls\"}" | base64 -w 0)"
    
    # Create account info file
    mkdir -p /var/www/html
    cat >/var/www/html/vmess-$user.txt <<-END
======================
     VMESS ACCOUNT
======================
Username     : $user
UUID         : $uuid
Quota        : $Quota GB
IP Limit     : $iplimit Devices
Domain       : $domain
ISP          : $ISP
City         : $CITY
======================
     CONNECTION LINKS
======================
Link TLS     : ${vmess_tls}
Link Non-TLS : ${vmess_http}
Link GRPC    : ${vmess_grpc}
======================
Created      : $tnggl
Expired      : $expe
Duration     : $masaaktif Days
======================
END

    # Set IP limit and quota
    if [[ $iplimit -gt 0 ]]; then
        mkdir -p /etc/peyx/limit/vmess/ip
        echo "$iplimit" > /etc/peyx/limit/vmess/ip/$user
        echo -e "${GREEN}✅ IP limit set: $iplimit device(s)${NC}"
    fi

    mkdir -p /etc/peyx/vmess
    if [[ $Quota -gt 0 ]]; then
        echo $(($Quota * 1024 * 1024 * 1024)) > /etc/peyx/vmess/$user
    fi

    # Save to database
    echo "### $user $exp $uuid $Quota $iplimit" >> /etc/peyx/vmess.db

    echo -e "${GREEN}✓ VMess account created${NC}"
    echo -e "${CYAN}Sending notifications...${NC}"
    
    # Notifikasi Telegram
    TEXT="
<b>---------------------------------------</b> 
<b> Peyx Tunneling Script</b>
<b>---------------------------------------</b>
<b>      XRAY/VMESS</b>
<b>---------------------------------------</b>
<code>Username  : ${user}
Domain    : ${domain}
Quota     : ${Quota} GB
Limit IP  : ${iplimit} Devices
UUID      : ${uuid}</code>
<b>---------------------------------------</b>
<b>🔗 VMESS WS TLS</b>
<code>${vmess_tls}</code>
<b>---------------------------------------</b>
<b>🔗 VMESS WS HTTP</b>
<code>${vmess_http}</code>
<b>---------------------------------------</b>
<b>📅 Expired : ${expe}</b>
<b>---------------------------------------</b>"

    send_telegram_notification "$TEXT" "false"

    # Notifikasi transaksi
    TEXT2="
<b>-----------------------------------------</b>
   <b>TRANSAKSI BERHASIL</b>
<b>-----------------------------------------</b>
<b>» Produk : VMess</b>
<b>» ISP :</b> ${ISP}
<b>» Domain :</b> ${domain}
<b>» Region :</b> ${CITY}
<b>» User :</b> ${user}
<b>» Aktif :</b> ${masaaktif} Hari
<b>» Limit IP :</b> ${iplimit} Devices
<b>» Dibuat   :</b> ${tnggl}
<b>» Berakhir :</b> ${expe}
<b>-----------------------------------------</b>"
    
    send_telegram_notification "$TEXT2" "true"
    
    echo -e "${GREEN}✓ Notifications sent${NC}"
    
    clear
    
    # Display result
    echo -e "\n${GREEN}✅ VMess Account Created Successfully!${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    echo -e "${WHITE}     ACCOUNT DETAILS${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    echo -e "${CYAN}Username         ${WHITE}: ${GREEN}$user${NC}"
    echo -e "${CYAN}UUID             ${WHITE}: ${GREEN}$uuid${NC}"
    echo -e "${CYAN}Quota            ${WHITE}: ${YELLOW}$Quota GB${NC}"
    echo -e "${CYAN}IP Limit         ${WHITE}: ${YELLOW}$iplimit Device(s)${NC}"
    echo -e "${CYAN}Duration         ${WHITE}: ${YELLOW}$masaaktif Days${NC}"
    echo -e "${CYAN}Domain           ${WHITE}: ${GREEN}$domain${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    
    echo -e "\n${WHITE}     CONFIGURATION INFO${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    echo -e "${CYAN}Link TLS (443)   ${WHITE}: ${GREEN}$vmess_tls${NC}"
    echo ""
    echo -e "${CYAN}Link HTTP (80)   ${WHITE}: ${GREEN}$vmess_http${NC}"
    echo ""
    echo -e "${CYAN}Link GRPC        ${WHITE}: ${GREEN}$vmess_grpc${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    
    echo -e "\n${WHITE}        EXPIRY INFO${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    echo -e "${CYAN}Created          ${WHITE}: ${GREEN}$tnggl${NC}"
    echo -e "${CYAN}Expires          ${WHITE}: ${YELLOW}$expe${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    
    echo -e "\n${GREEN}📢 Notifications sent to Telegram!${NC}"
    echo -e "\n${BLUE}------------------------------${NC}"
    echo -e "${PURPLE}        Script By${NC}"
    echo -e "${YELLOW}         $nama${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    
    echo -e "\n${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
}

# Main execution
Create_VMess_Account