#!/bin/bash

# Color Definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BG_BLUE='\033[44;1m'
BG_GREEN='\033[42;1m'
BG_RED='\033[41;1m'
NC='\033[0m'
BOLD='\033[1m'

# Animation Characters
SPINNER=("вЈ·" "вЈҜ" "вЈҹ" "вЎҝ" "вўҝ" "вЈ»" "вЈҪ" "вЈҫ")

# Konfigurasi
ZIVPN_CONFIG="/etc/zivpn/config.json"
ZIVPN_USERS="/etc/zivpn/users.json"
domain=$(cat /etc/zivpn/domain 2>/dev/null || echo "Tidak ada")
ISP=$(curl -s ipinfo.io/org 2>/dev/null | cut -d " " -f 2-10 || echo "Unknown")
CITY=$(curl -s ipinfo.io/city 2>/dev/null || echo "Unknown")
MYIP=$(curl -sS ipv4.icanhazip.com 2>/dev/null)

# Function to display header
display_header() {
    clear
    echo -e "${BLUE}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
    echo -e "${BLUE}в”Ӯ${YELLOW}    в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—${BLUE}    в”Ӯ${NC}"
    echo -e "${BLUE}в”Ӯ${YELLOW}    в•‘       рҹҡҖ CREATE ZIVPN USER            в•‘${BLUE}    в”Ӯ${NC}"
    echo -e "${BLUE}в”Ӯ${YELLOW}    в•‘       Premium Edition                 в•‘${BLUE}    в”Ӯ${NC}"
    echo -e "${BLUE}в”Ӯ${YELLOW}    в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ${BLUE}    в”Ӯ${NC}"
    echo -e "${BLUE}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}"
    echo
}

# Loading animation
show_loading() {
    local text=$1
    echo -ne "${CYAN}${text} ${NC}"
    for i in {1..3}; do
        for char in "${SPINNER[@]}"; do
            echo -ne "\r${CYAN}${text} $char ${NC}"
            sleep 0.1
        done
    done
    echo -ne "\r${GREEN}${text} вң“ ${NC}"
    echo
}

# ==================== TELEGRAM NOTIFICATION FUNCTION (BAWAAN) ====================
send_telegram_notification() {
    local action="$1"
    local username="$2"
    local expired="$3"
    local iplimit="$4"
    local domain_info="$5"
    
    local bot_config="/etc/zivpn/bot-config.json"
    
    if [ ! -f "$bot_config" ]; then
        return 1
    fi
    
    local bot_token=$(grep -o '"bot_token": "[^"]*"' "$bot_config" | cut -d'"' -f4)
    local admin_id=$(grep -o '"admin_id": [0-9]*' "$bot_config" | cut -d' ' -f2)
    
    if [ -z "$bot_token" ] || [ -z "$admin_id" ]; then
        return 1
    fi
    
    # Bersihkan kode warna ANSI
    local clean_username=$(echo "$username" | sed 's/\x1b\[[0-9;]*m//g')
    local clean_expired=$(echo "$expired" | sed 's/\x1b\[[0-9;]*m//g')
    local clean_iplimit=$(echo "$iplimit" | sed 's/\x1b\[[0-9;]*m//g')
    local clean_domain=$(echo "$domain_info" | sed 's/\x1b\[[0-9;]*m//g')
    local datetime_now=$(date '+%Y-%m-%d %H:%M:%S')
    
    local message=""
    
    case "$action" in
        "create")
            message="рҹ”җ *USER CREATED* рҹ”җ
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
рҹ‘Ө *Password:* \`$clean_username\`
рҹ“… *Expired:* $clean_expired
рҹҢҗ *IP Limit:* $clean_iplimit
рҹҸ·пёҸ *Domain:* \`$clean_domain\`
вҸ° *Time:* $datetime_now
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
вң… User has been successfully created!"
            ;;
        "create_random")
            message="рҹҺІ *RANDOM USER CREATED* рҹҺІ
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
рҹ‘Ө *Password:* \`$clean_username\`
рҹ“… *Expired:* $clean_expired
рҹҢҗ *IP Limit:* $clean_iplimit
рҹҸ·пёҸ *Domain:* $clean_domain
вҸ° *Time:* \`$datetime_now\`
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
вң… Random user has been successfully created!"
            ;;
        "trial")
            message="вҸұпёҸ *TRIAL USER CREATED* вҸұпёҸ
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
рҹ‘Ө *Password:* \`$clean_username\`
вҸ° *Expired:* $clean_expired (30 minutes)
рҹҢҗ *IP Limit:* $clean_iplimit
рҹҸ·пёҸ *Domain:* \`$clean_domain\`
вҸ° *Time:* $datetime_now
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
рҹҺ« Trial user will expire in 30 minutes!"
            ;;
        "renew")
            message="рҹ”„ *USER RENEWED* рҹ”„
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
рҹ‘Ө *Password:* \`$clean_username\`
рҹ“… *New Expired:* $clean_expired
рҹҢҗ *IP Limit:* $clean_iplimit
рҹҸ·пёҸ *Domain:* \`$clean_domain\`
вҸ° *Time:* $datetime_now
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
вң… User has been successfully renewed!"
            ;;
        "delete")
            message="рҹ—‘пёҸ *USER DELETED* рҹ—‘пёҸ
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
рҹ‘Ө *Password:* \`$clean_username\`
вҸ° *Time:* $datetime_now
в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
вқҢ User has been removed from system!"
            ;;
        *)
            return 1
            ;;
    esac
    
    # Kirim notifikasi
    local url="https://api.telegram.org/bot${bot_token}/sendMessage"
    local response=$(curl -s -X POST "$url" \
        -d "chat_id=${admin_id}" \
        -d "text=${message}" \
        -d "parse_mode=Markdown")
    
    if echo "$response" | grep -q '"ok":true'; then
        echo -e "   ${GREEN}вң… Telegram notification sent${NC}"
        return 0
    else
        local error_msg=$(echo "$response" | grep -o '"description":"[^"]*"' | cut -d'"' -f4)
        echo -e "   ${RED}вң— Telegram failed: ${error_msg:-Unknown error}${NC}"
        return 1
    fi
}

# Main function
Create_ZiVPN_User() {
    display_header
    
    echo -e "\n${BG_GREEN}${WHITE} CREATE ZIVPN ACCOUNT ${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    echo
    
    echo -e "${CYAN}в•ӯв”Җ ACCOUNT DETAILS ${NC}"
    echo -e "${CYAN}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    echo -e "${WHITE}Enter account information${NC}"
    
    echo -ne "${PURPLE}вһӨ Password / Username: ${NC}"
    read password
    
    # Validasi input password
    if [[ -z "$password" ]]; then
        echo -e "\n${RED}вқҢ Error: Password cannot be empty!${NC}"
        sleep 2
        return 1
    fi
    
    echo -ne "${PURPLE}вһӨ Duration (days): ${NC}"
    read days
    
    # Validasi input duration
    if ! [[ "$days" =~ ^[0-9]+$ ]] || [ "$days" -lt 1 ]; then
        echo -e "\n${RED}вқҢ Error: Please enter valid days! (minimum 1)${NC}"
        sleep 2
        return 1
    fi
    
    echo -ne "${PURPLE}вһӨ IP Limit (0 = unlimited): ${NC}"
    read iplimit
    
    show_loading "Creating ZiVPN account"
    
    exp_date=$(date -d "+$days days" +%Y-%m-%d)
    tgl=$(date -d "+$days days" +"%d")
    bln=$(date -d "+$days days" +"%b")
    thn=$(date -d "+$days days" +"%Y")
    expe="$tgl $bln, $thn"
    tgl2=$(date +"%d")
    bln2=$(date +"%b")
    thn2=$(date +"%Y")
    tnggl="$tgl2 $bln2, $thn2"
    
    # Save to config.json
    python3 << PYTHON
import json
with open("$ZIVPN_CONFIG", "r") as f:
    config = json.load(f)
if "$password" not in config["auth"]["config"]:
    config["auth"]["config"].append("$password")
with open("$ZIVPN_CONFIG", "w") as f:
    json.dump(config, f, indent=4)

try:
    with open("$ZIVPN_USERS", "r") as f:
        users = json.load(f)
except:
    users = []

users.append({
    "password": "$password",
    "expired": "$exp_date",
    "ip_limit": ${iplimit:-0},
    "status": "active",
    "created_at": "$(date '+%Y-%m-%d %H:%M:%S')"
})
with open("$ZIVPN_USERS", "w") as f:
    json.dump(users, f, indent=4)
PYTHON
    
    show_loading "Restarting service"
    systemctl restart zivpn 2>/dev/null
    
    show_loading "Saving account data"
    
    # Create account info file
    mkdir -p /var/www/html/zivpn
    cat > /var/www/html/zivpn/$password.txt <<- END
==============================
        ZIVPN ACCOUNT
==============================
Password     : $password
IP Limit     : ${iplimit:-0} Devices
Domain       : $domain
ISP          : $ISP
City         : $CITY
Server IP    : $MYIP
==============================
        PORT CONFIGURATION
==============================
ZiVPN Port   : 5667
API Port     : 8585
==============================
Created      : $tnggl
Expired      : $expe
Duration     : $days Days
==============================
END
    
    # Kirim notifikasi Telegram
    show_loading "Sending Telegram notification"
    send_telegram_notification "create" "$password" "$exp_date" "${iplimit:-0}" "$domain"
    
    clear
    
    # Display result
    echo -e "\n${GREEN}вң… ZiVPN Account Created Successfully!${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    echo -e "${WHITE}              ACCOUNT DETAILS${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    echo -e "${CYAN}Password         ${WHITE}: ${GREEN}$password${NC}"
    echo -e "${CYAN}Duration         ${WHITE}: ${YELLOW}$days Days${NC}"
    echo -e "${CYAN}IP Limit         ${WHITE}: ${YELLOW}${iplimit:-0} Device(s)${NC}"
    echo -e "${CYAN}Domain           ${WHITE}: ${GREEN}$domain${NC}"
    echo -e "${CYAN}ISP              ${WHITE}: ${GREEN}$ISP${NC}"
    echo -e "${CYAN}City             ${WHITE}: ${GREEN}$CITY${NC}"
    echo -e "${CYAN}Server IP        ${WHITE}: ${GREEN}$MYIP${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    
    echo -e "\n${WHITE}           CONNECTION INFO${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    echo -e "${CYAN}ZiVPN Port       ${WHITE}: ${GREEN}5667${NC}"
    echo -e "${CYAN}API Port         ${WHITE}: ${GREEN}8585${NC}"
    echo -e "${CYAN}Account File     ${WHITE}: ${GREEN}http://$MYIP:8585/zivpn/$password.txt${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    
    echo -e "\n${WHITE}            EXPIRY INFO${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    echo -e "${CYAN}Created          ${WHITE}: ${GREEN}$tnggl${NC}"
    echo -e "${CYAN}Expires          ${WHITE}: ${YELLOW}$expe${NC}"
    echo -e "${CYAN}Duration         ${WHITE}: ${YELLOW}$days Days${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    
    echo -e "\n${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    echo -e "${PURPLE}              Script By PeyxDev${NC}"
    echo -e "${BLUE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
    
    # Wait for user input
    echo -e "\n${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
}

# Run main function
Create_ZiVPN_User