#!/bin/bash

# Color Definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BG_BLUE='\033[44;1m'
BG_GREEN='\033[42;1m'
BG_RED='\033[41;1m'
NC='\033[0m'
BOLD='\033[1m'

# Function to display header
display_header() {
    clear
    echo -e "${BLUE}┌─────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${YELLOW}    ╔═══════════════════════╗${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║   🚀 TRIAL VLESS      ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║   Premium Edition     ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ╚═══════════════════════╝${BLUE}    │${NC}"
    echo -e "${BLUE}└─────────────────────────────────┘${NC}"
    echo
}

# Get system information
ISP=$(curl -s ipinfo.io/org | cut -d " " -f 2-10 2>/dev/null || echo "Unknown ISP")
CITY=$(curl -s ipinfo.io/city 2>/dev/null || echo "Unknown City")
domain=$(cat /etc/zivpn/domain 2>/dev/null || echo "example.com")
nama=$(cat /etc/zivpn/username 2>/dev/null || echo "PEYX TUNNEL")
IP=$(curl -sS ipv4.icanhazip.com 2>/dev/null || echo "Unknown IP")

# ==================== BOT CONFIGURATION (DARI /etc/zivpn/bot-config.json) ====================
BOT_CONFIG="/etc/zivpn/bot-config.json"

get_bot_config() {
    if [ -f "$BOT_CONFIG" ]; then
        KEY=$(grep -o '"bot_token": "[^"]*"' "$BOT_CONFIG" | cut -d'"' -f4)
        CHATIDS=$(grep -o '"admin_id": [0-9]*' "$BOT_CONFIG" | cut -d' ' -f2)
        echo "$KEY|$CHATIDS"
    else
        echo "|"
    fi
}

BOT_INFO=$(get_bot_config)
KEY=$(echo "$BOT_INFO" | cut -d'|' -f1)
CHATIDS=$(echo "$BOT_INFO" | cut -d'|' -f2)
TIME="10"
URL="https://api.telegram.org/bot$KEY/sendMessage"

# Transaction bot (gunakan bot yang sama)
KEY2="$KEY"
CHATID2="$CHATIDS"
URL2="https://api.telegram.org/bot$KEY2/sendMessage"

# Function to send Telegram notification
send_telegram_notification() {
    local message="$1"
    local is_transaction="$2"
    
    local target_chatid="$CHATIDS"
    local target_url="$URL"
    
    if [ "$is_transaction" = "true" ]; then
        target_chatid="$CHATID2"
        target_url="$URL2"
    fi
    
    if [ -n "$target_chatid" ] && [ -n "$KEY" ]; then
        curl -s --max-time "$TIME" -X POST "$target_url" \
            -d "chat_id=${target_chatid}" \
            -d "disable_web_page_preview=1" \
            -d "parse_mode=html" \
            --data-urlencode "text=${message}" >/dev/null
    fi
}

# Function to create trial Vless account
Create_Trial_Vless() {
    display_header
    echo -e "\n${BG_GREEN}${WHITE} CREATE TRIAL VLESS ACCOUNT ${NC}"
    echo -e "${BLUE}───────────────────────────────────${NC}"
    echo
    
    # Custom username input
    echo -e "${CYAN}╭─ CUSTOM USERNAME INPUT ${NC}"
    echo -e "${CYAN}╰────────────────────────${NC}"
    echo -e "${WHITE}Enter custom username for trial account${NC}"
    echo -ne "${PURPLE}➤ Username: ${NC}"
    read user
    
    if [[ -z "$user" ]]; then
        echo -e "\n${RED}❌ Error: Username cannot be empty!${NC}"
        sleep 2
        return 1
    fi
    
    # Input trial duration
    echo -e "\n${CYAN}╭─ TRIAL DURATION ${NC}"
    echo -e "${CYAN}╰─────────────────${NC}"
    echo -e "${WHITE}Enter trial duration in minutes${NC}"
    echo -e "${YELLOW}Example: 30 (30 menit), 60 (60 menit)${NC}"
    echo -ne "${PURPLE}➤ Minutes: ${NC}"
    read waktu_ekspirasi_menit
    
    if ! [[ "$waktu_ekspirasi_menit" =~ ^[0-9]+$ ]] || [ "$waktu_ekspirasi_menit" -lt 1 ]; then
        echo -e "\n${RED}❌ Error: Please enter valid minutes!${NC}"
        sleep 2
        return 1
    fi
    
    echo -e "${CYAN}Creating trial Vless account...${NC}"
    
    # Set default UUID
    uuid="pxstore"
    Quota=1
    iplimit=1
    
    # Hitung expiry date
    expiry_date=$(date -d "+$waktu_ekspirasi_menit minutes" +"%Y-%m-%d")
    exp=$expiry_date
    expe=$(date -d "+$waktu_ekspirasi_menit minutes" +"%d %b %Y %H:%M")
    tnggl=$(date +"%d %b %Y %H:%M")
    
    # ==================== TAMBAH USER KE XRAY (PAKAI JQ) ====================
    echo -e "${CYAN}Adding user to Xray config...${NC}"
    
    if ! grep -q '"protocol": "vless"' /usr/local/etc/xray/config.json; then
        echo -e "${RED}❌ Error: VLESS inbound not found in config!${NC}"
        return 1
    fi
    
    jq --arg uuid "$uuid" --arg user "$user" \
       '.inbounds |= map(if .protocol == "vless" then 
           .settings.clients += [{"id": $uuid, "email": $user}] 
       else . end)' /usr/local/etc/xray/config.json > /usr/local/etc/xray/config.json.tmp && \
       mv /usr/local/etc/xray/config.json.tmp /usr/local/etc/xray/config.json
    
    if [ $? -ne 0 ]; then
        echo -e "${RED}❌ Error: Failed to add user to config!${NC}"
        return 1
    fi
    
    systemctl restart xray
    
    # Create Vless links
    vless_tls="vless://${uuid}@${domain}:443?encryption=none&security=tls&type=ws&host=${domain}&path=/vless&sni=${domain}#${user}"
    vless_http="vless://${uuid}@${domain}:80?encryption=none&security=none&type=ws&host=${domain}&path=/vless#${user}"
    vless_grpc="vless://${uuid}@${domain}:443?encryption=none&security=tls&type=grpc&serviceName=vless-grpc&sni=${domain}#${user}"
 
    # Create account info file
    mkdir -p /var/www/html
    cat >/var/www/html/vless-$user.txt <<-END
==============================
     TRIAL VLESS ACCOUNT
==============================
Username     : $user
UUID         : $uuid
Quota        : $Quota GB
IP Limit     : $iplimit Devices
Domain       : $domain
ISP          : $ISP
City         : $CITY
==============================
     CONNECTION LINKS
==============================
Link TLS     : ${vless_tls}
Link HTTP    : ${vless_http}
Link GRPC    : ${vless_grpc}
==============================
Created      : $tnggl
Expired      : $expe
Duration     : $waktu_ekspirasi_menit Minutes
==============================
END

    # Set IP limit
    if [[ $iplimit -gt 0 ]]; then
        mkdir -p /etc/peyx/limit/vless/ip
        echo "$iplimit" > /etc/peyx/limit/vless/ip/$user
    fi

    # Save to trial database
    mkdir -p /etc/peyx
    echo "### $user $exp $uuid $Quota $iplimit" >> /etc/peyx/vless_trial.db

    # ==================== AUTO DELETE ====================
    echo -e "${CYAN}Setting up auto deletion in ${waktu_ekspirasi_menit} minutes...${NC}"
    
    # Create deletion script
    cat > /usr/local/bin/delete_trial_vless_${user}.sh << DELETESCRIPT
#!/bin/bash
# Auto delete trial user: $user
jq --arg user "$user" '.inbounds |= map(if .protocol == "vless" then .settings.clients |= map(select(.email != \$user)) else . end)' /usr/local/etc/xray/config.json > /usr/local/etc/xray/config.json.tmp && mv /usr/local/etc/xray/config.json.tmp /usr/local/etc/xray/config.json
rm -f /etc/peyx/limit/vless/ip/$user
rm -f /var/www/html/vless-$user.txt
sed -i "/### $user /d" /etc/peyx/vless_trial.db
systemctl restart xray
rm -f /usr/local/bin/delete_trial_vless_${user}.sh
DELETESCRIPT

    chmod +x /usr/local/bin/delete_trial_vless_${user}.sh
    
    # Schedule deletion with at command
    echo "/usr/local/bin/delete_trial_vless_${user}.sh" | at now + ${waktu_ekspirasi_menit} minutes 2>/dev/null
    
    # Also add to crontab as backup
    deletion_time=$(date -d "+${waktu_ekspirasi_menit} minutes" +"%M %H %d %m *")
    (crontab -l 2>/dev/null; echo "$deletion_time /usr/local/bin/delete_trial_vless_${user}.sh") | crontab - 2>/dev/null

    echo -e "${CYAN}Sending notifications...${NC}"
    
    # Notifikasi Telegram
    TEXT="
<b>------------------------------</b>    
<b> Peyx Tunneling Script</b>
<b>------------------------------</b>
<b>      TRIAL VLESS</b>
<b>------------------------------</b>
<code>Username  : ${user}
Domain    : ${domain}
Limit IP  : ${iplimit} Devices
UUID      : ${uuid}</code>
<b>------------------------------</b>
<b>🔗 VLESS WS TLS</b>
<code>${vless_tls}</code>
<b>------------------------------</b>
<b>🔗 VLESS WS HTTP</b>
<code>${vless_http}</code>
<b>------------------------------</b>
<b>📅 Expired : ${expe}</b>
<b>------------------------------</b>"

    send_telegram_notification "$TEXT" "false"

    # Notifikasi transaksi
    TEXT2="
<b>-----------------------------------------</b>
   <b>TRANSAKSI SUKSES</b>
<b>-----------------------------------------</b>
<b>» Produk : Trial VLess</b>
<b>» ISP :</b> ${ISP}
<b>» Region :</b> ${CITY}
<b>» User :</b> ${user}
<b>» Aktif :</b> ${waktu_ekspirasi_menit} Menit
<b>» Limit IP :</b> ${iplimit} Devices
<b>-----------------------------------------</b>"
    
    send_telegram_notification "$TEXT2" "true"
    
    echo -e "${GREEN}✓ Trial Vless account created${NC}"
    echo -e "${GREEN}✓ Notifications sent${NC}"
    
    clear
    
    # Display result
    echo -e "\n${GREEN}✅ Trial Vless Account Created Successfully!${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    echo -e "${WHITE}     ACCOUNT DETAILS${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    echo -e "${CYAN}Username         ${WHITE}: ${GREEN}$user${NC}"
    echo -e "${CYAN}UUID             ${WHITE}: ${GREEN}$uuid${NC}"
    echo -e "${CYAN}Duration         ${WHITE}: ${YELLOW}$waktu_ekspirasi_menit Minutes${NC}"
    echo -e "${CYAN}IP Limit         ${WHITE}: ${YELLOW}$iplimit Device(s)${NC}"
    echo -e "${CYAN}Domain           ${WHITE}: ${GREEN}$domain${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    
    echo -e "\n${WHITE}     CONFIGURATION INFO${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    echo -e "${CYAN}Link TLS (443)   ${WHITE}: ${GREEN}$vless_tls${NC}"
    echo ""
    echo -e "${CYAN}Link HTTP (80)   ${WHITE}: ${GREEN}$vless_http${NC}"
    echo ""
    echo -e "${CYAN}Link GRPC        ${WHITE}: ${GREEN}$vless_grpc${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    
    echo -e "\n${GREEN}📢 Notifications sent to Telegram!${NC}"
    echo -e "\n${BLUE}------------------------------${NC}"
    echo -e "${PURPLE}        Script By${NC}"
    echo -e "${YELLOW}         $nama${NC}"
    echo -e "${BLUE}------------------------------${NC}"
    
    echo -e "\n${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
}

# Main execution
Create_Trial_Vless