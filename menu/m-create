# ==================== KONFIGURASI ====================
domain=$(cat /etc/zivpn/domain 2>/dev/null || echo "Not Set")
nama=$(cat /etc/zivpn/username 2>/dev/null || echo "PEYX TUNNEL")

# ==================== HEADER ====================
clear
echo -e "\033[36;1m┌─────────────────────────────────────────────────┐\033[0m"
echo -e "\033[36;1m│\e[97m  \033[38;5;196m⁙\033[38;5;202m⁙\033[38;5;208m⁙\033[38;5;214m⁙\033[38;5;220m⁙\033[38;5;226m⁙\033[38;5;190m⁙\033[38;5;154m⁙\033[38;5;118m⁙\033[38;5;82m⁙\033[38;5;46m⁙\033[38;5;47m⁙\033[38;5;48m⁙\033[38;5;49m⁙\033[97m PEYX TUNNELING \033[38;5;87m⁙\033[38;5;86m⁙\033[38;5;85m⁙\033[38;5;84m⁙\033[38;5;83m⁙\033[38;5;44m⁙\033[38;5;43m⁙\033[38;5;42m⁙\033[38;5;41m⁙\033[38;5;40m⁙\033[38;5;39m⁙\033[38;5;38m⁙\033[38;5;37m⁙\033[38;5;36m⁙\033[97m   \033[36;1m│\033[0m"
echo -e "\033[36;1m└─────────────────────────────────────────────────┘\033[0m"

echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
echo -e "${BLUE}│${WHITE}                📡 ACCOUNT MENU                  ${BLUE}│${NC}"
echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
echo -e "${BLUE}│${WHITE}  [01]${WHITE} • Create VMESS Account${NC}               ${BLUE}     │"
echo -e "${BLUE}│${WHITE}  [02]${WHITE} • Create VLESS Account${NC}               ${BLUE}     │"
echo -e "${BLUE}│${WHITE}  [03]${WHITE} • Create Trojan Account${NC}              ${BLUE}     │"
echo -e "${BLUE}│${WHITE}  [04]${WHITE} • Create ZiVPN Account${NC}                ${BLUE}    │"
echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
echo -e "${BLUE}│${WHITE}  [05]${WHITE} • Trial VMESS Account${NC}               ${BLUE}      │"
echo -e "${BLUE}│${WHITE}  [06]${WHITE} • Trial VLESS Account${NC}                ${BLUE}     │"
echo -e "${BLUE}│${WHITE}  [07]${WHITE} • Trial Trojan Account${NC}                 ${BLUE}   │"
echo -e "${BLUE}│${WHITE}  [08]${WHITE} • Trial ZiVPN Account${NC}                 ${BLUE}    │"
echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
echo -e "${BLUE}│${WHITE}  [09]${WHITE} • List VMESS Account${NC}                  ${BLUE}    │"
echo -e "${BLUE}│${WHITE}  [10]${WHITE} • List VLESS Account${NC}                  ${BLUE}    │"
echo -e "${BLUE}│${WHITE}  [11]${WHITE} • List Trojan Account${NC}                  ${BLUE}   │"
echo -e "${BLUE}│${WHITE}  [12]${WHITE} • List ZiVPN Account${NC}                   ${BLUE}   │"
echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
echo -e "${BLUE}│${WHITE}  [13]${WHITE} • Delete Account${NC}                       ${BLUE}   │"
