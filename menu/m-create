echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
echo -e "${BLUE}│${PURPLE}              Script By : $nama${NC}${BLUE}              ${NC}"
echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
echo ""

read -p "   Pilih menu [00-17] : " menu

case $menu in
    1)
        clear
        if [ -f /usr/local/bin/add-vme ]; then
            add-vme
        else
            echo -e "${RED}❌ Script add-vme tidak ditemukan!${NC}"
            sleep 2
        fi
        ;;
    02)
        clear
        if [ -f /usr/local/bin/add-vle ]; then
            add-vle
        else
            echo -e "${RED}❌ Script add-vle tidak ditemukan!${NC}"
            sleep 2
        fi
        ;;
    3)
        clear
        if [ -f /usr/local/bin/add-tro ]; then
            add-tro
        else
            echo -e "${RED}❌ Script add-tro tidak ditemukan!${NC}"
            sleep 2
        fi
        ;;
    4)
        clear
        if [ -f /usr/local/bin/add-zivpn ]; then
            add-zivpn
        else
            echo -e "${RED}❌ Script add-zivpn tidak ditemukan!${NC}"
            sleep 2
        fi
        ;;
    5)
        clear
        if [ -f /usr/local/bin/trial-vme ]; then
            trial-vme
        else
            echo -e "${RED}❌ Script trial-vme tidak ditemukan!${NC}"
            sleep 2
        fi
        ;;
    6)
        clear
        if [ -f /usr/local/bin/trial-vle ]; then
            trial-vle
        else
            echo -e "${RED}❌ Script trial-vle tidak ditemukan!${NC}"
            sleep 2
        fi
        ;;
    7)
        clear
        if [ -f /usr/local/bin/trial-tro ]; then
            trial-tro
        else
            echo -e "${RED}❌ Script trial-tro tidak ditemukan!${NC}"
            sleep 2
        fi
        ;;
    8)
        clear
        if [ -f /usr/local/bin/trial-zivpn ]; then
            trial-zivpn
        else
            echo -e "${RED}❌ Script trial-zivpn tidak ditemukan!${NC}"
            sleep 2
        fi
        ;;
    9)
        clear
        if [ -f /usr/local/bin/member-vme ]; then
            member-vme
        else
            echo -e "${RED}❌ Script member-vme tidak ditemukan!${NC}"
            sleep 2
        fi
        ;;
    10)
        clear
        if [ -f /usr/local/bin/member-vle ]; then
