    13)
        clear
        echo -e "${BLUE}════════════════════════════════════════${NC}"
        echo -e "${GREEN}         DELETE ACCOUNT${NC}"
        echo -e "${BLUE}════════════════════════════════════════${NC}"
        echo ""
        echo -e "${CYAN}1. Delete VMESS${NC}"
        echo -e "${CYAN}2. Delete VLESS${NC}"
        echo -e "${CYAN}3. Delete Trojan${NC}"
        echo -e "${CYAN}4. Delete ZiVPN${NC}"
        echo -e "${CYAN}0. Back${NC}"
        read -p "Pilih: " del_opt
        case $del_opt in
            1) del-vme ;;
            2) del-vle ;;
            3) del-tro ;;
            4) del-zivpn ;;
            0) m-create ;;
        esac
        ;;
    14)
        clear
        echo -e "${BLUE}════════════════════════════════════════${NC}"
        echo -e "${GREEN}         RENEW ACCOUNT${NC}"
        echo -e "${BLUE}════════════════════════════════════════${NC}"
        echo ""
        echo -e "${CYAN}1. Renew VMESS${NC}"
        echo -e "${CYAN}2. Renew VLESS${NC}"
        echo -e "${CYAN}3. Renew Trojan${NC}"
        echo -e "${CYAN}4. Renew ZiVPN${NC}"
        echo -e "${CYAN}0. Back${NC}"
        read -p "Pilih: " renew_opt
        case $renew_opt in
            1) renew-vme ;;
            2) renew-vle ;;
            3) renew-tro ;;
            4) renew-zivpn ;;
            0) m-create ;;
        esac
        ;;
    15)
        clear
        echo -e "${BLUE}════════════════════════════════════════${NC}"
        echo -e "${GREEN}         LOCK/UNLOCK ACCOUNT${NC}"
        echo -e "${BLUE}════════════════════════════════════════${NC}"
        echo ""
        echo -e "${CYAN}1. Lock VMESS${NC}"
        echo -e "${CYAN}2. Lock VLESS${NC}"
        echo -e "${CYAN}3. Lock Trojan${NC}"
        echo -e "${CYAN}0. Back${NC}"
        read -p "Pilih: " lock_opt
        case $lock_opt in
            1) lock-vm ;;
            2) lock-vl ;;
            3) lock-tr ;;
            0) m-create ;;
        esac
        ;;
    00)
        clear
        menu 0
        ;;
    *)
        echo -e "${RED}Pilihan salah!${NC}"
        sleep 1
        ;;
esac

# Kembali ke menu
exec $0