#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BG_GREEN='\033[42;1m'
NC='\033[0m'

SPINNER=("⣷" "⣯" "⣟" "⡿" "⢿" "⣻" "⣽" "⣾")

ZIVPN_CONFIG="/etc/zivpn/config.json"
ZIVPN_USERS="/etc/zivpn/users.json"
domain=$(cat /etc/zivpn/domain 2>/dev/null || echo "Tidak ada")

display_header() {
    clear
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${YELLOW}    ╔═══════════════════════════════════════╗${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║       🔄 RENEW ZIVPN USER             ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║       Premium Edition                 ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ╚═══════════════════════════════════════╝${BLUE}    │${NC}"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
    echo
}

show_loading() {
    local text=$1
    echo -ne "${CYAN}${text} ${NC}"
    for i in {1..3}; do
        for char in "${SPINNER[@]}"; do
            echo -ne "\r${CYAN}${text} $char ${NC}"
            sleep 0.1
        done
    done
    echo -ne "\r${GREEN}${text} ✓ ${NC}"
    echo
}

send_telegram_notification() {
    local action="$1"
    local username="$2"
    local expired="$3"
    
    local bot_config="/etc/zivpn/bot-config.json"
    
    if [ ! -f "$bot_config" ]; then
        return 1
    fi
    
    local bot_token=$(grep -o '"bot_token": "[^"]*"' "$bot_config" | cut -d'"' -f4)
    local admin_id=$(grep -o '"admin_id": [0-9]*' "$bot_config" | cut -d' ' -f2)
    
    if [ -z "$bot_token" ] || [ -z "$admin_id" ]; then
        return 1
    fi
    
    local clean_username=$(echo "$username" | sed 's/\x1b\[[0-9;]*m//g')
    local clean_expired=$(echo "$expired" | sed 's/\x1b\[[0-9;]*m//g')
    local datetime_now=$(date '+%Y-%m-%d %H:%M:%S')
    
    local message="🔄 *USER RENEWED* 🔄
━━━━━━━━━━━━━━━━━━━━
👤 *Password:* \`$clean_username\`
📅 *New Expired:* $clean_expired
⏰ *Time:* $datetime_now
━━━━━━━━━━━━━━━━━━━━
✅ User has been successfully renewed!"
    
    local url="https://api.telegram.org/bot${bot_token}/sendMessage"
    curl -s -X POST "$url" -d "chat_id=${admin_id}" -d "text=${message}" -d "parse_mode=Markdown" >/dev/null
}

Renew_ZiVPN_User() {
    display_header
    
    echo -e "\n${BG_GREEN}${WHITE} RENEW ZIVPN ACCOUNT ${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    echo
    
    echo -e "${CYAN}╭─ ACCOUNT TO RENEW ${NC}"
    echo -e "${CYAN}╰────────────────────────────────────────────────${NC}"
    echo -ne "${PURPLE}➤ Password / Username: ${NC}"
    read password
    
    if [[ -z "$password" ]]; then
        echo -e "\n${RED}❌ Error: Password cannot be empty!${NC}"
        sleep 2
        return 1
    fi
    
    echo -ne "${PURPLE}➤ Add days: ${NC}"
    read days
    
    if ! [[ "$days" =~ ^[0-9]+$ ]] || [ "$days" -lt 1 ]; then
        echo -e "\n${RED}❌ Error: Please enter valid days!${NC}"
        sleep 2
        return 1
    fi
    
    show_loading "Renewing ZiVPN account"
    
    python3 << PYTHON
import json
from datetime import datetime, timedelta

with open("$ZIVPN_USERS", "r") as f:
    users = json.load(f)

new_exp_date = ""
for u in users:
    if u.get("password") == "$password":
        current_exp = u.get("expired", datetime.now().strftime("%Y-%m-%d"))
        new_exp = datetime.strptime(current_exp, "%Y-%m-%d") + timedelta(days=$days)
        new_exp_date = new_exp.strftime("%Y-%m-%d")
        u["expired"] = new_exp_date
        u["status"] = "active"
        if "is_trial" in u:
            del u["is_trial"]

with open("$ZIVPN_USERS", "w") as f:
    json.dump(users, f, indent=4)

with open("$ZIVPN_CONFIG", "r") as f:
    config = json.load(f)
if "$password" not in config["auth"]["config"]:
    config["auth"]["config"].append("$password")
with open("$ZIVPN_CONFIG", "w") as f:
    json.dump(config, f, indent=4)

with open("/tmp/zivpn_new_exp.txt", "w") as f:
    f.write(new_exp_date)
PYTHON
    
    new_exp_date=$(cat /tmp/zivpn_new_exp.txt 2>/dev/null)
    rm -f /tmp/zivpn_new_exp.txt
    
    show_loading "Restarting service"
    systemctl restart zivpn 2>/dev/null
    
    show_loading "Sending Telegram notification"
    send_telegram_notification "renew" "$password" "$new_exp_date"
    
    clear
    
    echo -e "\n${GREEN}✅ ZiVPN Account Renewed Successfully!${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    echo -e "${CYAN}Password         ${WHITE}: ${GREEN}$password${NC}"
    echo -e "${CYAN}New Expired      ${WHITE}: ${YELLOW}$new_exp_date${NC}"
    echo -e "${CYAN}Added Days       ${WHITE}: ${YELLOW}$days Days${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    
    echo -e "\n${BLUE}─────────────────────────────────────────────────${NC}"
    echo -e "${PURPLE}              Script By PeyxDev${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    
    echo -e "\n${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
}

Renew_ZiVPN_User