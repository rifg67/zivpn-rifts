# Main loop
while true; do
    show_menu
    
    case $choice in
        1) restart_all ;;
        2) restart_xray ;;
        3) restart_nginx ;;
        4) restart_zivpn_core ;;
        5) restart_api ;;
        6) restart_bot ;;
        0) 
            clear
            echo -e "${GREEN}Returning to main menu...${NC}"
            sleep 1
            exit 0
            ;;
        *) 
            echo -e "\n${RED}Pilihan salah!${NC}"
            sleep 1
            ;;
    esac
done