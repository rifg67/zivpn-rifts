#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'

SPINNER=("⣷" "⣯" "⣟" "⡿" "⢿" "⣻" "⣽" "⣾")

# Konfigurasi
API_PORT=8585

display_header() {
    clear
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${YELLOW}    ╔═══════════════════════════════════════╗${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║       🔄 RESTART SERVICE              ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ║       Premium Edition                 ║${BLUE}    │${NC}"
    echo -e "${BLUE}│${YELLOW}    ╚═══════════════════════════════════════╝${BLUE}    │${NC}"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
    echo
}

show_loading() {
    local text=$1
    echo -ne "${CYAN}${text} ${NC}"
    for i in {1..3}; do
        for char in "${SPINNER[@]}"; do
            echo -ne "\r${CYAN}${text} $char ${NC}"
            sleep 0.1
        done
    done
    echo -ne "\r${GREEN}${text} ✓ ${NC}"
    echo
}

show_menu() {
    display_header
    
    echo -e "\n${YELLOW}─────────────────────────────────────────────────${NC}"
    echo -e "${WHITE}              PILIH SERVICE${NC}"
    echo -e "${YELLOW}─────────────────────────────────────────────────${NC}"
    echo -e "${GREEN}  [1]${WHITE} Restart ALL Services${NC}"
    echo -e "${GREEN}  [2]${WHITE} Restart Xray Only${NC}"
    echo -e "${GREEN}  [3]${WHITE} Restart Nginx Only${NC}"
    echo -e "${GREEN}  [4]${WHITE} Restart ZiVPN Only${NC}"
    echo -e "${GREEN}  [5]${WHITE} Restart ZiVPN API Only${NC}"
    echo -e "${GREEN}  [6]${WHITE} Restart ZiVPN Bot Only${NC}"
    echo -e "${RED}  [0]${WHITE} Back to Main Menu${NC}"
    echo -e "${YELLOW}─────────────────────────────────────────────────${NC}"
    echo
    read -p "   Pilih opsi [0-6] : " choice
}

restart_all() {
    clear
    display_header
    
    echo -e "\n${YELLOW}─────────────────────────────────────────────────${NC}"
    echo -e "${WHITE}              RESTARTING ALL SERVICES${NC}"
    echo -e "${YELLOW}─────────────────────────────────────────────────${NC}"
    echo
    
    show_loading "Restarting Xray service"
    systemctl restart xray 2>/dev/null
    
    show_loading "Restarting Nginx service"
    systemctl restart nginx 2>/dev/null
    
    show_loading "Restarting ZiVPN Core service"
    systemctl restart zivpn 2>/dev/null
    
    show_loading "Restarting ZiVPN API service"
    systemctl restart zivpn-api-js 2>/dev/null
    
    show_loading "Restarting ZiVPN Bot service"
    systemctl restart zivpn-bot 2>/dev/null
    
    sleep 2
    
    clear
    display_header
    echo -e "\n${GREEN}✅ All services restarted successfully!${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────${NC}"
    echo -e "\n${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
}

restart_xray() {
    clear
    display_header
    
    echo -e "\n${YELLOW}─────────────────────────────────────────────────${NC}"
    echo -e "${WHITE}              RESTARTING XRAY ONLY${NC}"
    echo -e "${YELLOW}─────────────────────────────────────────────────${NC}"
    echo
    
    show_loading "Restarting Xray service"
    systemctl restart xray 2>/dev/null
    
    sleep 1
    
    if systemctl is-active --quiet xray; then
        echo -e "\n${GREEN}✅ Xray is running${NC}"
    else
        echo -e "\n${RED}❌ Xray failed to start${NC}"
    fi
    
    echo -e "\n${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
}

