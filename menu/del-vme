#!/bin/bash

dateFromServer=$(curl -v --insecure --silent https://google.com/ 2>&1 | grep Date | sed -e 's/< Date: //')
biji=`date +"%Y-%m-%d" -d "$dateFromServer"`

# Color Definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'
BOLD='\033[1m'

# ==================== BOT CONFIGURATION (DARI /etc/zivpn/bot-config.json) ====================
BOT_CONFIG="/etc/zivpn/bot-config.json"

get_bot_config() {
    if [ -f "$BOT_CONFIG" ]; then
        KEY=$(grep -o '"bot_token": "[^"]*"' "$BOT_CONFIG" | cut -d'"' -f4)
        CHATIDS=$(grep -o '"admin_id": [0-9]*' "$BOT_CONFIG" | cut -d' ' -f2)
        echo "$KEY|$CHATIDS"
    else
        echo "|"
    fi
}

BOT_INFO=$(get_bot_config)
KEY=$(echo "$BOT_INFO" | cut -d'|' -f1)
CHATIDS=$(echo "$BOT_INFO" | cut -d'|' -f2)
TIME="10"
URL="https://api.telegram.org/bot$KEY/sendMessage"

# Transaction bot (gunakan bot yang sama)
KEY2="$KEY"
CHATID2="$CHATIDS"
URL2="https://api.telegram.org/bot$KEY2/sendMessage"

# Function to display header
display_header() {
    clear
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${YELLOW}        ╔═══════════════════════════╗${BLUE}            │${NC}"
    echo -e "${BLUE}│${YELLOW}        ║      🗑️ DELETE VMESS       ║${BLUE}            │${NC}"
    echo -e "${BLUE}│${YELLOW}        ║       Premium Edition     ║${BLUE}            │${NC}"
    echo -e "${BLUE}│${YELLOW}        ╚═══════════════════════════╝${BLUE}            │${NC}"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
    echo
}

# Function to display credit
display_credit() {
    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${PURPLE}           Terimakasih Telah Menggunakan${BLUE}         │${NC}"
    echo -e "${BLUE}│${PURPLE}                  Script Credit${BLUE}                  │${NC}"
    nama=$(cat /etc/zivpn/username 2>/dev/null || echo "PEYX TUNNEL")
    printf "${BLUE}│${PURPLE}                  %-30s ${BLUE}│${NC}\n" "$nama"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
    systemctl restart xray >/dev/null 2>&1
    service cron restart >/dev/null 2>&1
    exit 1
}

# Function to get users from database (bukan dari config.json)
get_users_from_db() {
    if [ -f "/etc/peyx/vmess.db" ]; then
        grep "^###" /etc/peyx/vmess.db | awk '{print $2" "$3}'
    fi
}

# Function to count users
count_users() {
    get_users_from_db | wc -l
}

# Function to check if user exists in database
user_exists() {
    local user="$1"
    grep -q "^### $user " /etc/peyx/vmess.db 2>/dev/null
}

# Function to get user expiration from database
get_user_expiration() {
    local user="$1"
    grep "^### $user " /etc/peyx/vmess.db | awk '{print $3}'
}

# Function to get user quota and IP limit from database
get_user_info() {
    local user="$1"
    local info=$(grep "^### $user " /etc/peyx/vmess.db 2>/dev/null)
    QUOTA=$(echo "$info" | awk '{print $4}')
    IPLIMIT=$(echo "$info" | awk '{print $5}')
    UUID=$(echo "$info" | awk '{print $4}')
    
    # Set default values
    if [[ -z "$QUOTA" ]] || [[ "$QUOTA" = "" ]]; then
        QUOTA="0"
    fi
    if [[ -z "$IPLIMIT" ]] || [[ "$IPLIMIT" = "" ]]; then
        IPLIMIT="0"
    fi
}

# Function to send Telegram notification
send_telegram_notification() {
    local message="$1"
    local is_transaction="$2"
    
    local target_chatid="$CHATIDS"
    local target_url="$URL"
    
    if [ "$is_transaction" = "true" ]; then
        target_chatid="$CHATID2"
        target_url="$URL2"
    fi
    
    if [ -n "$target_chatid" ] && [ -n "$KEY" ]; then
        curl -s --max-time "$TIME" -X POST "$target_url" \
            -d "chat_id=${target_chatid}" \
            -d "disable_web_page_preview=1" \
            -d "parse_mode=html" \
            --data-urlencode "text=${message}" >/dev/null
    fi
}

# Function to show loading animation
show_loading() {
    local duration=3
    local frames=("██10%" "█████35%" "█████████65%" "█████████████80%" "█████████████████████90%" "█████████████████████████100%")
    local num_frames=${#frames[@]}
    local num_iterations=$((duration))

    for ((i = 0; i < num_iterations; i++)); do
        clear
        index=$((i % num_frames))
        color_code=$((31 + i % 7))
        echo ""
        echo ""
        echo ""
        echo -e "\e[1;${color_code}m ${frames[$index]}\e[0m"
        sleep 0.5
    done
}

# Function to show success message
show_success() {
    clear
    echo -e "${GREEN}✅ Success${NC}"
    sleep 1
    clear
}

# Main function
main() {
    display_header

    NUMBER_OF_CLIENTS=$(count_users)
    if [[ ${NUMBER_OF_CLIENTS} == '0' ]]; then
        echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
        echo -e "${BLUE}│${RED}           ❌ AKUN TIDAK DITEMUKAN${BLUE}               │${NC}"
        echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
        echo -e "${BLUE}│${WHITE}      Tidak ada akun VMESS yang aktif!${BLUE}        │${NC}"
        echo -e "${BLUE}│${WHITE}        Silakan buat akun terlebih dahulu${BLUE}     │${NC}"
        echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
        read -p "$(echo -e "${CYAN}📝 Press Enter to continue...${NC}")"
        return
    fi

    echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
    echo -e "${BLUE}│${WHITE}             📊 VMESS ACCOUNT LIST${BLUE}               │${NC}"
    echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
    echo -e "${BLUE}│${WHITE}  USERNAME         EXP DATE         STATUS${BLUE}       │${NC}"
    echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"

    # Display user accounts from database
    while read -r line; do
        user=$(echo "$line" | awk '{print $1}')
        exp=$(echo "$line" | awk '{print $2}')
        if [[ -n "$user" && -n "$exp" ]]; then
            printf "${BLUE}│${WHITE}  %-15s %-15s ${GREEN}%-10s${WHITE}   ${BLUE}  │${NC}\n" "$user" "$exp" "ACTIVE"
        fi
    done < <(get_users_from_db)

    echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
    printf "${BLUE}│${WHITE} %-16s: ${GREEN}%-26s${BLUE}    │${NC}\n" "Total Accounts" "$NUMBER_OF_CLIENTS users"
    echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
    echo

    read -p "$(echo -e "${CYAN}📝 Ketik Username yang akan dihapus: ${NC}")" user

    if [ -z "$user" ]; then
        show_loading
        show_success
        return
    fi

    # Check if user exists in database
    if user_exists "$user"; then
        echo -e "\n${YELLOW}⏳ Menghapus user $user...${NC}"

        exp=$(get_user_expiration "$user")
        
        # Get user info before deletion
        get_user_info "$user"

        # ==================== HAPUS USER DARI XRAY CONFIG (PAKAI JQ) ====================
        jq --arg user "$user" '.inbounds |= map(if .protocol == "vmess" then .settings.clients |= map(select(.email != $user)) else . end)' /usr/local/etc/xray/config.json > /usr/local/etc/xray/config.json.tmp && mv /usr/local/etc/xray/config.json.tmp /usr/local/etc/xray/config.json
        
        # Remove user from vmess database
        sed -i "/^### $user /d" /etc/peyx/vmess.db
        
        # Also remove from trial database if exists
        sed -i "/^### $user /d" /etc/peyx/vmess_trial.db 2>/dev/null

        # Add to deleted users database for history
        mkdir -p /etc/peyx/deleted
        echo "### $user $UUID $exp" >>/etc/peyx/deleted/vmess_deleted.db 2>/dev/null

        # Remove user files
        rm -rf "/etc/peyx/vmess/$user" 2>/dev/null
        rm -rf "/etc/peyx/limit/vmess/ip/${user}" 2>/dev/null
        rm -rf "/var/www/html/vmess-$user.txt" 2>/dev/null

        # Restart service
        systemctl restart xray >/dev/null 2>&1

        # Send notification to Telegram
        TEXT="
<code>------------------------------</code>
<b>🗑️ DELETE VMESS ACCOUNT</b>
<code>------------------------------</code>
<code>Username    : $user</code>
<code>Quota       : $QUOTA GB</code>
<code>Limit IP    : $IPLIMIT Device</code>
<code>Expired     : $exp</code>
<code>Status      : DELETED</code>
<code>Time        : $(date '+%d %b %Y %H:%M:%S')</code>
<code>------------------------------</code>"

        send_telegram_notification "$TEXT" "false"

        # Transaction notification
        TEXT2="
<b>-----------------------------------------</b>
   <b>🗑️ DELETE VMESS ACCOUNT</b>
<b>-----------------------------------------</b>
<b>Status : BERHASIL DIHAPUS ✅</b>
<b>User : ${user}</b>
<b>Quota : ${QUOTA} GB</b>
<b>Limit IP : ${IPLIMIT} Device</b>
<b>Expired : ${exp}</b>
<b>Waktu : $(date '+%d %b %Y %H:%M:%S')</b>
<b>-----------------------------------------</b>
<i>Automatic Notification From Server...</i>"
        
        send_telegram_notification "$TEXT2" "true"

        # Display success message
        echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
        echo -e "${BLUE}│${GREEN}           ✅ BERHASIL DIHAPUS${BLUE}                   │${NC}"
        echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
        printf "${BLUE}│${WHITE} %-12s: %-30s ${BLUE}   │${NC}\n" "Client Name" "$user"
        printf "${BLUE}│${WHITE} %-12s: %-30s ${BLUE}   │${NC}\n" "Expired On" "$exp"
        echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
        echo -e "${GREEN}📢 Notifikasi telah dikirim ke Telegram${NC}"

        display_credit
    else
        echo -e "${BLUE}┌─────────────────────────────────────────────────┐${NC}"
        echo -e "${BLUE}│${RED}           ❌ USER TIDAK DITEMUKAN${BLUE}               │${NC}"
        echo -e "${BLUE}├─────────────────────────────────────────────────┤${NC}"
        echo -e "${BLUE}│${WHITE}             User $user tidak ditemukan!${BLUE}            │${NC}"
        echo -e "${BLUE}│${WHITE}           Pastikan username sudah benar${BLUE}         │${NC}"
        echo -e "${BLUE}└─────────────────────────────────────────────────┘${NC}"
        read -p "$(echo -e "${CYAN}📝 Press Enter to continue...${NC}")"
    fi
}

# Run main function
main