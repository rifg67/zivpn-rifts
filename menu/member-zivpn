#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
PURPLE='\033[0;35m'
NC='\033[0m' # No Color

ZIVPN_USERS="/etc/zivpn/users.json"
ZIVPN_CONFIG="/etc/zivpn/config.json"

display_header() {
    clear
    echo -e "${YELLOW}ZIVPN USER MANAGER - Premium Edition${NC}"
    echo -e "${BLUE}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    echo
}

# Function to delete expired accounts
delete_expired_accounts() {
    python3 << PYTHON
import json
from datetime import datetime

today = datetime.now().strftime("%Y-%m-%d")
deleted_users = []

try:
    with open("$ZIVPN_USERS", "r") as f:
        users = json.load(f)
except:
    users = []

# Filter out expired users
active_users = []
for u in users:
    exp = u.get("expired", "")
    status = u.get("status", "active")
    
    # Check if expired
    if exp and exp != "-" and exp < today and status != "locked":
        deleted_users.append(u.get("password", "unknown"))
        continue
    else:
        active_users.append(u)

# Save updated users
with open("$ZIVPN_USERS", "w") as f:
    json.dump(active_users, f, indent=2)

# Print deleted users
if deleted_users:
    print("DELETED:" + ",".join(deleted_users))
PYTHON
}

# Function to list users with proper formatting
List_ZiVPN_Users() {
    display_header
    
    # Check and delete expired accounts first
    echo -e "${YELLOW}Checking for expired accounts...${NC}"
    delete_output=$(delete_expired_accounts)
    
    if echo "$delete_output" | grep -q "DELETED:"; then
        deleted_users=$(echo "$delete_output" | cut -d':' -f2)
        deleted_count=$(echo "$deleted_users" | tr ',' '\n' | wc -l)
        echo -e "${GREEN}вњ“ Deleted $deleted_count expired account(s):${NC}"
        echo "$deleted_users" | tr ',' '\n' | while read user; do
            [ -n "$user" ] && echo -e "  ${RED}вњ—${NC} $user"
        done
    else
        echo -e "${GREEN}вњ“ No expired accounts found${NC}"
    fi
    
    echo -e "${BLUE}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    
    python3 << PYTHON
import json
from datetime import datetime

today = datetime.now().strftime("%Y-%m-%d")

try:
    with open("$ZIVPN_USERS", "r") as f:
        users = json.load(f)
except:
    users = []

if not users:
    print("\n  вљ  No users registered")
else:
    # Print header dengan warna putih untuk teks
    print("\033[1;37mPassword      Expired       Status    IP Limit\033[0m")
    print("\033[0;34mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m")
    
    for u in users:
        pwd = u.get("password", "-")[:12]
        exp = u.get("expired", "-")
        iplimit = str(u.get("ip_limit", 0))
        status = u.get("status", "active")
        
        # Check expiration
        if exp != "-" and exp < today and status != "locked":
            status = "expired"
        
        # Set status
        if status == "active":
            status_display = "Active"
        elif status == "locked":
            status_display = "Locked"
        else:
            status_display = "Expired"
        
        # Print dengan warna putih untuk password dan data user
        print(f"\033[1;37m{pwd:<12}\033[0m \033[1;37m{exp:<12}\033[0m \033[1;37m{status_display:<8}\033[0m \033[1;37m{iplimit:<10}\033[0m")
    
    # Summary
    active_count = 0
    expired_count = 0
    locked_count = 0
    trial_count = 0
    
    for u in users:
        exp = u.get("expired", "-")
        status = u.get("status", "active")
        is_trial = u.get("is_trial", False)
        
        if is_trial:
            trial_count += 1
        
        if status == "locked":
            locked_count += 1
        elif exp != "-" and exp < today:
            expired_count += 1
        else:
            active_count += 1
    
    print(f"\n\033[1;37mSummary: Active: {active_count} | Expired: {expired_count} | Locked: {locked_count} | Trial: {trial_count}\033[0m")
PYTHON
    
    echo -e "${BLUE}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    echo -e "${PURPLE}Script By PeyxDev${NC}"
    echo -e "${BLUE}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    
    echo -e "\n${CYAN}Press Enter to continue...${NC}"
    read -n 1 -s
}

# Main menu loop
while true; do
    List_ZiVPN_Users
    
    # Menu options after displaying users
    clear
    display_header
    echo -e "${YELLOW}MENU USER MANAGER${NC}"
    echo -e "${BLUE}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
    echo
    echo -e "${GREEN}1.${WHITE} Refresh User List"
    echo -e "${GREEN}2.${WHITE} Delete Expired Accounts Now"
    echo -e "${GREEN}0.${WHITE} Back to Main Menu"
    echo
    echo -ne "${PURPLE}вћ¤ Select menu : ${NC}"
    read menu_opt
    
    case $menu_opt in
        1)
            continue
            ;;
        2)
            clear
            display_header
            echo -e "${YELLOW}Manually deleting expired accounts...${NC}"
            delete_output=$(delete_expired_accounts)
            if echo "$delete_output" | grep -q "DELETED:"; then
                deleted_users=$(echo "$delete_output" | cut -d':' -f2)
                deleted_count=$(echo "$deleted_users" | tr ',' '\n' | wc -l)
                echo -e "${GREEN}вњ“ Deleted $deleted_count expired account(s):${NC}"
                echo "$deleted_users" | tr ',' '\n' | while read user; do
                    [ -n "$user" ] && echo -e "  ${RED}вњ—${NC} $user"
                done
            else
                echo -e "${GREEN}вњ“ No expired accounts found${NC}"
            fi
            echo -e "${BLUE}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"
            echo -e "\n${CYAN}Press Enter to continue...${NC}"
            read -n 1 -s
            ;;
        0)
            clear
            echo -e "${GREEN}Returning to Main Menu...${NC}"
            sleep 1
            exit 0
            ;;
        *)
            echo -e "${RED}Invalid option!${NC}"
            sleep 1
            ;;
    esac
done